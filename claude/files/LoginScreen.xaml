<?xml version="1.0" encoding="utf-8" ?>
<!--
  LoginScreen.xaml  —  Theme: Teal Explorer
  Code-behind: LoginScreen.xaml.cs (không thay đổi)
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="client.lib.screens.login.LoginScreen"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Background image + overlay -->
        <Image Source="vinh_khanh_night.jpg" Aspect="AspectFill"/>
        <BoxView BackgroundColor="#55000000"/>

        <!-- Close button -->
        <Border WidthRequest="36" HeightRequest="36"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                BackgroundColor="#33FFFFFF"
                VerticalOptions="Start" HorizontalOptions="End"
                Margin="20,48,20,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseClicked"/>
            </Border.GestureRecognizers>
            <Label Text="✕" FontSize="16" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <ScrollView>
            <VerticalStackLayout VerticalOptions="EndAndExpand"
                                 Padding="24,0,24,0"
                                 Spacing="0">

                <!-- ─── Spacer top ─── -->
                <BoxView HeightRequest="100" BackgroundColor="Transparent"/>

                <!-- ─── Brand / Logo area ─── -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center"
                                     Margin="0,0,0,32">
                    <Border WidthRequest="72" HeightRequest="72"
                            StrokeShape="RoundRectangle 36"
                            StrokeThickness="0"
                            BackgroundColor="#1ABC9C"
                            HorizontalOptions="Center">
                        <Label Text="🍜" FontSize="34"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Chào mừng trở lại!"
                           TextColor="White" FontSize="26"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,10,0,0"/>
                    <Label Text="Đăng nhập để khám phá ẩm thực Vĩnh Khánh"
                           TextColor="#CCCCCC" FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- ─── Card form ─── -->
                <Border StrokeShape="RoundRectangle 24"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.20" Radius="20" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">

                        <Label Text="Đăng nhập"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               Margin="0,0,0,4"/>

                        <!-- Username -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="👤"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="UsernameEntry"
                                       Grid.Column="1"
                                       Placeholder="Tên đăng nhập"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Password -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="🔒"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="1"
                                       Placeholder="Mật khẩu"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Forgot password -->
                        <Label Text="Quên mật khẩu?"
                               TextColor="#1ABC9C"
                               HorizontalOptions="End"
                               FontSize="13" FontAttributes="Bold"/>

                        <!-- Login button -->
                        <Button Text="ĐĂNG NHẬP"
                                Clicked="OnLoginClicked"
                                HeightRequest="54"
                                CornerRadius="27"
                                FontAttributes="Bold" FontSize="15"
                                TextColor="White"
                                BackgroundColor="#1ABC9C"
                                Margin="0,8,0,0"/>

                        <!-- Divider -->
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="5" Margin="0,4,0,4">
                            <BoxView WidthRequest="50" HeightRequest="1"
                                     BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                            <Label Text="hoặc" TextColor="#AAAAAA" FontSize="13"/>
                            <BoxView WidthRequest="50" HeightRequest="1"
                                     BackgroundColor="#EEEEEE" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Register link -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                            <Label Text="Chưa có tài khoản?"
                                   TextColor="#636E72" VerticalOptions="Center" FontSize="14"/>
                            <Label Text="Đăng ký ngay"
                                   TextColor="#1ABC9C"
                                   FontAttributes="Bold"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center" FontSize="14">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGoToRegisterTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="30" BackgroundColor="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
