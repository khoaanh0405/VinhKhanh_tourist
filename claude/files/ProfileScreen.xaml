<?xml version="1.0" encoding="utf-8" ?>
<!--
  ProfileScreen.xaml  —  Theme: Teal Explorer
  Code-behind: ProfileScreen.xaml.cs (không thay đổi)
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="client.lib.screens.login.ProfileScreen"
             BackgroundColor="#F5F6FA"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ HEADER HERO ═══ -->
            <Grid HeightRequest="220">
                <Image Source="vinh_khanh_night.jpg" Aspect="AspectFill"/>
                <!-- Teal gradient overlay -->
                <BoxView>
                    <BoxView.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="#AA0A3D33" Offset="0.0"/>
                            <GradientStop Color="#CC1ABC9C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>

                <!-- Back button -->
                <Border WidthRequest="36" HeightRequest="36"
                        StrokeShape="RoundRectangle 18"
                        StrokeThickness="0"
                        BackgroundColor="#33FFFFFF"
                        VerticalOptions="Start" HorizontalOptions="Start"
                        Margin="20,48,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackButtonClicked"/>
                    </Border.GestureRecognizers>
                    <Label Text="←" FontSize="18" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>

                <Label Text="Tài khoản của tôi"
                       TextColor="White" FontSize="17" FontAttributes="Bold"
                       HorizontalOptions="Center" VerticalOptions="Start"
                       Margin="0,52,0,0"/>

                <!-- Avatar floating -->
                <Border WidthRequest="90" HeightRequest="90"
                        StrokeShape="RoundRectangle 45"
                        StrokeThickness="3" Stroke="White"
                        BackgroundColor="#1ABC9C"
                        HorizontalOptions="Center"
                        VerticalOptions="End"
                        Margin="0,0,0,-45">
                    <Label Text="👤" FontSize="44"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- ═══ NAME + USERNAME ═══ -->
            <VerticalStackLayout Spacing="4"
                                 HorizontalOptions="Center"
                                 Margin="0,56,0,24">
                <Label x:Name="WelcomeLabel"
                       Text="Đang tải..."
                       FontSize="22" FontAttributes="Bold"
                       TextColor="#1A1A2E"
                       HorizontalOptions="Center"/>
                <Border HeightRequest="24" Padding="12,0"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="#E8F8F5"
                        HorizontalOptions="Center">
                    <Label Text="Thành viên Vĩnh Khánh"
                           FontSize="12" TextColor="#1ABC9C"
                           FontAttributes="Bold"/>
                </Border>
            </VerticalStackLayout>

            <!-- ═══ ACCOUNT INFO CARD ═══ -->
            <Border Margin="20,0,20,16"
                    Padding="20"
                    StrokeShape="RoundRectangle 20"
                    StrokeThickness="0"
                    BackgroundColor="White">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.07" Radius="10" Offset="0,3"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">

                    <Label Text="Thông tin tài khoản"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="#1A1A2E" Margin="0,0,0,14"/>

                    <!-- Username row -->
                    <Grid ColumnDefinitions="Auto, *, Auto"
                          ColumnSpacing="12" Padding="0,10,0,10">
                        <Border Grid.Column="0"
                                WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0" BackgroundColor="#E8F8F5">
                            <Label Text="👤" FontSize="16"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Tên đăng nhập"
                                   FontSize="11" TextColor="#AAAAAA"/>
                            <Label x:Name="UsernameLabel"
                                   Text="..."
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#1A1A2E"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="#CCCCCC" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="48,0,0,0"/>

                    <!-- Language row -->
                    <Grid ColumnDefinitions="Auto, *, Auto"
                          ColumnSpacing="12" Padding="0,10,0,10">
                        <Border Grid.Column="0"
                                WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0" BackgroundColor="#EAF4FB">
                            <Label Text="🌐" FontSize="16"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Ngôn ngữ" FontSize="11" TextColor="#AAAAAA"/>
                            <Label Text="Tiếng Việt (Mặc định)"
                                   FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="#CCCCCC" VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" BackgroundColor="#F5F5F5" Margin="48,0,0,0"/>

                    <!-- Privacy row -->
                    <Grid ColumnDefinitions="Auto, *, Auto"
                          ColumnSpacing="12" Padding="0,10,0,0">
                        <Border Grid.Column="0"
                                WidthRequest="36" HeightRequest="36"
                                StrokeShape="RoundRectangle 18"
                                StrokeThickness="0" BackgroundColor="#FFF3E0">
                            <Label Text="🛡️" FontSize="16"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Bảo mật &amp; Quyền riêng tư"
                                   FontSize="11" TextColor="#AAAAAA"/>
                            <Label Text="Quản lý quyền riêng tư"
                                   FontSize="15" FontAttributes="Bold" TextColor="#1A1A2E"/>
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="›" FontSize="20"
                               TextColor="#CCCCCC" VerticalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- ═══ LOGOUT BUTTON ═══ -->
            <Button Text="Đăng xuất"
                    Clicked="OnLogoutClicked"
                    Margin="20,0,20,10"
                    HeightRequest="54"
                    CornerRadius="27"
                    FontAttributes="Bold" FontSize="15"
                    TextColor="#FF4757"
                    BackgroundColor="#FFF0F2"
                    BorderColor="#FFDDDD"
                    BorderWidth="1"/>

            <BoxView HeightRequest="30" BackgroundColor="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
