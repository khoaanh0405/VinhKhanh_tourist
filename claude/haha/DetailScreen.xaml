<?xml version="1.0" encoding="utf-8" ?>
<!--
  DetailScreen.xaml  —  Theme: Teal Explorer
  ══════════════════════════════════════════════════════════════
  Code-behind: DetailScreen.xaml.cs  (KHÔNG THAY ĐỔI GÌ)
  Tất cả x:Name được giữ nguyên 100%:
    ImgCarousel, IndicatorView, LblName, LblDescription,
    ListFoodsContainer, ReviewInputFrame, Star1–Star5,
    CommentEditor, BtnShowReviewInput, ListReviewsContainer,
    BtnFavorite
  ══════════════════════════════════════════════════════════════
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:client.lib.model"
             x:Class="client.lib.screens.home.DetailScreen"
             BackgroundColor="#F5F6FA"
             Shell.NavBarIsVisible="False">

    <!-- Root Grid: full-screen layout -->
    <Grid RowDefinitions="*, Auto">

        <!-- ══════════════════════════════════════════════════ -->
        <!--  SCROLLABLE BODY                                   -->
        <!-- ══════════════════════════════════════════════════ -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ─── HERO IMAGE SECTION ─── -->
                <Grid HeightRequest="300">

                    <!-- Image Carousel (full bleed) -->
                    <Border StrokeShape="RoundRectangle 0"
                            StrokeThickness="0"
                            IsClippedToBounds="True">
                        <CarouselView x:Name="ImgCarousel"
                                      Loop="False"
                                      IndicatorView="IndicatorView">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding .}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill"
                                           VerticalOptions="Fill"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                    </Border>

                    <!-- Gradient overlay (bottom) -->
                    <BoxView VerticalOptions="End" HeightRequest="160">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#E0000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Gradient overlay (top — for back button legibility) -->
                    <BoxView VerticalOptions="Start" HeightRequest="100">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#88000000" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button -->
                    <Border WidthRequest="38" HeightRequest="38"
                            StrokeShape="RoundRectangle 19"
                            StrokeThickness="0"
                            BackgroundColor="#44000000"
                            VerticalOptions="Start"
                            HorizontalOptions="Start"
                            Margin="16,48,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="←" FontSize="18" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Dot Indicator -->
                    <IndicatorView x:Name="IndicatorView"
                                   IndicatorColor="#66FFFFFF"
                                   SelectedIndicatorColor="#1ABC9C"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,0,14"
                                   IndicatorSize="8"/>

                </Grid>

                <!-- ─── INFO CARD (slides up over image) ─── -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 28,28,0,0"
                        StrokeThickness="0"
                        Padding="22,24,22,0"
                        Margin="0,-24,0,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Radius="16" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <!-- Drag handle -->
                        <BoxView WidthRequest="40" HeightRequest="4"
                                 CornerRadius="2"
                                 BackgroundColor="#E0E0E0"
                                 HorizontalOptions="Center"
                                 Margin="0,0,0,18"/>

                        <!-- Name -->
                        <Label x:Name="LblName"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               Margin="0,0,0,10"/>

                        <!-- Rating + Review count row -->
                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,10">
                            <Border HeightRequest="28" Padding="12,0"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    BackgroundColor="#FFF8E6"
                                    VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="⭐" FontSize="13"/>
                                    <Label Text="{Binding AverageRating, StringFormat='{0:F1}'}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="#E67E22"/>
                                </HorizontalStackLayout>
                            </Border>
                            <Label Text="{Binding ReviewCount, StringFormat='· {0} đánh giá'}"
                                   FontSize="13" TextColor="#AAAAAA"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Location row -->
                        <HorizontalStackLayout Spacing="6" Margin="0,0,0,18">
                            <Label Text="📍" FontSize="14" TextColor="#1ABC9C"
                                   VerticalOptions="Center"/>
                            <Label Text="Khu ẩm thực Vĩnh Khánh"
                                   TextColor="#636E72" FontSize="14"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Description -->
                        <Label x:Name="LblDescription"
                               TextColor="#636E72"
                               FontSize="14"
                               LineHeight="1.6"
                               Margin="0,0,0,22"/>

                    </VerticalStackLayout>
                </Border>

                <!-- ─── MENU SECTION ─── -->
                <VerticalStackLayout BackgroundColor="#F5F6FA"
                                     Padding="22,20,22,20"
                                     Spacing="14">

                    <!-- Section header -->
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22"
                                StrokeShape="RoundRectangle 2"
                                StrokeThickness="0"
                                BackgroundColor="#1ABC9C"
                                VerticalOptions="Center"/>
                        <Label Text="Thực đơn nổi bật"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Food items injected by code-behind -->
                    <StackLayout x:Name="ListFoodsContainer" Spacing="10"/>

                </VerticalStackLayout>

                <!-- ─── REVIEWS SECTION ─── -->
                <VerticalStackLayout BackgroundColor="White"
                                     Padding="22,22,22,22"
                                     Spacing="14">

                    <!-- Section header -->
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22"
                                StrokeShape="RoundRectangle 2"
                                StrokeThickness="0"
                                BackgroundColor="#1ABC9C"
                                VerticalOptions="Center"/>
                        <Label Text="Đánh giá &amp; Bình luận"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- ── WRITE REVIEW BUTTON ── -->
                    <Border x:Name="BtnShowReviewInput"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1.5" Stroke="#E8F8F5"
                            BackgroundColor="#F0FCF8"
                            HeightRequest="48"
                            Padding="16,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShowReviewInputClicked"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Label Text="✏️" FontSize="16"/>
                            <Label Text="Viết đánh giá của bạn"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#1ABC9C"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ── REVIEW INPUT FORM ── -->
                    <Border x:Name="ReviewInputFrame"
                            IsVisible="False"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="1" Stroke="#E8F8F5"
                            BackgroundColor="#FAFFFE"
                            Padding="18,16">
                        <VerticalStackLayout Spacing="14">

                            <Label Text="Đánh giá của bạn"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#1A1A2E"
                                   HorizontalOptions="Center"/>

                            <!-- Star selector -->
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label x:Name="Star1" Text="☆" FontSize="36"
                                       TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star2" Text="☆" FontSize="36"
                                       TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star3" Text="☆" FontSize="36"
                                       TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star4" Text="☆" FontSize="36"
                                       TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star5" Text="☆" FontSize="36"
                                       TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>

                            <!-- Comment editor -->
                            <Border StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1.5" Stroke="#EFEFEF"
                                    BackgroundColor="White" Padding="12,4">
                                <Editor x:Name="CommentEditor"
                                        Placeholder="Chia sẻ trải nghiệm của bạn tại đây..."
                                        PlaceholderColor="#BBBBBB"
                                        MinimumHeightRequest="80"
                                        AutoSize="TextChanges"
                                        BackgroundColor="Transparent"
                                        TextColor="#1A1A2E"
                                        FontSize="14"/>
                            </Border>

                            <!-- Action buttons -->
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Huỷ bỏ"
                                        Clicked="OnCancelReviewClicked"
                                        HeightRequest="46"
                                        CornerRadius="23"
                                        BackgroundColor="#F5F6FA"
                                        TextColor="#636E72"
                                        FontAttributes="Bold"
                                        FontSize="14"/>
                                <Button Grid.Column="1"
                                        Text="Gửi đánh giá"
                                        Clicked="OnSubmitReviewClicked"
                                        HeightRequest="46"
                                        CornerRadius="23"
                                        BackgroundColor="#1ABC9C"
                                        TextColor="White"
                                        FontAttributes="Bold"
                                        FontSize="14"/>
                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- Review list (injected by code-behind) -->
                    <StackLayout x:Name="ListReviewsContainer" Spacing="10"/>

                </VerticalStackLayout>

                <!-- Bottom spacer so FAB doesn't cover last review -->
                <BoxView HeightRequest="90" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════════════════ -->
        <!--  BOTTOM ACTION BAR (Favorite button)              -->
        <!-- ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                StrokeThickness="0"
                Padding="20,12,20,32">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.10" Radius="12" Offset="0,-3"/>
            </Border.Shadow>
            <Button x:Name="BtnFavorite"
                    Text="❤️  Thêm vào yêu thích"
                    Clicked="OnFavoriteClicked"
                    HeightRequest="54"
                    CornerRadius="27"
                    BackgroundColor="#FF4757"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"/>
        </Border>

    </Grid>
</ContentPage>
