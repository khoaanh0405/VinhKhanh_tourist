<?xml version="1.0" encoding="utf-8" ?>
<!--
  POIDetailPage.xaml  —  Theme: Teal Explorer
  Mở từ luồng QR scanner (POIDetailPage.xaml.cs nhận poiId và bind ViewModel).
  Code-behind: POIDetailPage.xaml.cs (KHÔNG THAY ĐỔI GÌ)
-->
<ContentPage
    x:Class="client.lib.screens.poi.POIDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F6FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ─── HERO IMAGE ─── -->
                <Grid HeightRequest="280">
                    <Image Source="{Binding Poi.ImageUrl}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill"/>

                    <!-- Bottom gradient -->
                    <BoxView VerticalOptions="End" HeightRequest="140">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#D9000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Top gradient for back button -->
                    <BoxView VerticalOptions="Start" HeightRequest="90">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#88000000" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Back button -->
                    <Border WidthRequest="38" HeightRequest="38"
                            StrokeShape="RoundRectangle 19"
                            StrokeThickness="0"
                            BackgroundColor="#44000000"
                            VerticalOptions="Start" HorizontalOptions="Start"
                            Margin="16,48,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="←" FontSize="18" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- QR badge -->
                    <Border WidthRequest="80" HeightRequest="26"
                            StrokeShape="RoundRectangle 13"
                            StrokeThickness="0"
                            BackgroundColor="#CC1ABC9C"
                            VerticalOptions="Start" HorizontalOptions="End"
                            Margin="0,52,16,0">
                        <Label Text="📷 QR Scan" FontSize="11"
                               TextColor="White" FontAttributes="Bold"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Name overlay -->
                    <Label Text="{Binding Poi.Name}"
                           TextColor="White"
                           FontSize="22" FontAttributes="Bold"
                           VerticalOptions="End"
                           Margin="18,0,18,16"
                           MaxLines="2" LineBreakMode="TailTruncation"/>
                </Grid>

                <!-- ─── INFO CARD ─── -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 28,28,0,0"
                        StrokeThickness="0"
                        Padding="22,22,22,0"
                        Margin="0,-24,0,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Radius="16" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">

                        <!-- Drag handle -->
                        <BoxView WidthRequest="40" HeightRequest="4"
                                 CornerRadius="2" BackgroundColor="#E0E0E0"
                                 HorizontalOptions="Center"/>

                        <!-- Location -->
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="📍" FontSize="14" TextColor="#1ABC9C"
                                   VerticalOptions="Center"/>
                            <Label Text="Khu ẩm thực Vĩnh Khánh"
                                   TextColor="#636E72" FontSize="14"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Narration text -->
                        <Label Text="{Binding CurrentNarration.Text}"
                               FontSize="14" TextColor="#636E72"
                               LineHeight="1.6"/>

                        <!-- Action buttons -->
                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12"
                              Margin="0,4,0,20">
                            <Button Grid.Column="0"
                                    Text="▶  Phát thuyết minh"
                                    Command="{Binding PlayAudioCommand}"
                                    HeightRequest="50"
                                    CornerRadius="25"
                                    BackgroundColor="#1ABC9C"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    FontSize="13"/>
                            <Button Grid.Column="1"
                                    Text="{Binding IsFavorite, Converter={StaticResource BoolToFavoriteTextConverter}}"
                                    Command="{Binding ToggleFavoriteCommand}"
                                    HeightRequest="50"
                                    CornerRadius="25"
                                    TextColor="{Binding IsFavorite, Converter={StaticResource BoolToColorConverter}}"
                                    BackgroundColor="#FFF0F2"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    BorderColor="#FFDDDD"
                                    BorderWidth="1"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ─── NEARBY RESTAURANTS ─── -->
                <VerticalStackLayout BackgroundColor="#F5F6FA"
                                     Padding="22,20,22,20"
                                     Spacing="14">

                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22"
                                StrokeShape="RoundRectangle 2"
                                StrokeThickness="0"
                                BackgroundColor="#1ABC9C"
                                VerticalOptions="Center"/>
                        <Label Text="Quán ăn gần đây"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding Poi.Restaurants}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="16"
                                        StrokeShape="RoundRectangle 14"
                                        StrokeThickness="0"
                                        BackgroundColor="White">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Opacity="0.06" Radius="8" Offset="0,2"/>
                                    </Border.Shadow>
                                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                        <Border WidthRequest="36" HeightRequest="36"
                                                StrokeShape="RoundRectangle 18"
                                                StrokeThickness="0"
                                                BackgroundColor="#E8F8F5">
                                            <Label Text="🍽️" FontSize="16"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <Label Text="{Binding Name}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="#1A1A2E"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
