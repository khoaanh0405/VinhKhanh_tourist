<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:loc="clr-namespace:client.lib.core"
             x:Class="client.lib.screens.map.MapPage"
             Shell.NavBarIsVisible="False">

    <Grid>
        <maps:Map x:Name="MyMap" IsShowingUser="True"/>

        <!-- Go-to-my-location button -->
        <Border WidthRequest="48" HeightRequest="48"
                StrokeShape="RoundRectangle 24" StrokeThickness="0"
                BackgroundColor="White"
                VerticalOptions="Start" HorizontalOptions="End"
                Margin="0,50,16,0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Opacity="0.15" Radius="8"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGoToMyLocationClicked"/>
            </Border.GestureRecognizers>
            <Label Text="🎯" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- Horizontal restaurant card list -->
        <CollectionView x:Name="RestaurantList"
                        VerticalOptions="End"
                        HeightRequest="175"
                        Margin="0,0,0,20"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border WidthRequest="310" Margin="16,4,0,4" Padding="0"
                            StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Opacity="0.10" Radius="12"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="104, *" RowDefinitions="*, Auto">

                            <Border Grid.Column="0" Grid.RowSpan="2"
                                    StrokeShape="RoundRectangle 16,0,0,16" StrokeThickness="0">
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"
                                       HeightRequest="170" WidthRequest="104"/>
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Grid.Row="0"
                                                 Margin="12,10,12,0" Spacing="3" VerticalOptions="Start">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="14"
                                       TextColor="#1A1A2E" MaxLines="1" LineBreakMode="TailTruncation"/>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="⭐" FontSize="11" VerticalOptions="Center" TextColor="#FFB800"/>
                                    <Label Text="{Binding AverageRating}" TextColor="#1A1A2E" FontAttributes="Bold" FontSize="12"/>
                                    <Label Text="·" TextColor="#CCCCCC" FontSize="12"/>
                                    <Label Text="{Binding DistanceStr}" TextColor="#1ABC9C" FontAttributes="Bold" FontSize="12"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Description}" FontSize="11" TextColor="#636E72"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <Button Grid.Column="1" Grid.Row="1"
                                    Margin="12,4,12,10"
                                    Text="{loc:Translate MapButtonDetail}"
                                    HeightRequest="32" CornerRadius="16"
                                    BackgroundColor="#1ABC9C" TextColor="White"
                                    FontSize="12" FontAttributes="Bold" Padding="0"
                                    Clicked="OnDetailButtonClicked"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
