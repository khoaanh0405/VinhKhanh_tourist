<?xml version="1.0" encoding="utf-8" ?>
<!--
  MapPage.xaml — Theme: Teal Explorer
  🔥 NÂNG CẤP:
    - Sort theo DistanceKm (double) thay vì DistanceStr (string)
    - Thêm 2 nút: "Dẫn đường" + "Chi tiết" trên mỗi card
    - Fuzzy search (code-behind)
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="client.lib.screens.map.MapPage"
             xmlns:loc="clr-namespace:client.lib.core"
             Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Full-screen Map -->
        <maps:Map x:Name="MyMap" IsShowingUser="True"/>

        <!-- ─── TOP SEARCH BAR ─── -->
        <Border Margin="16,50,16,0"
                VerticalOptions="Start"
                StrokeShape="RoundRectangle 26"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,3" Opacity="0.12" Radius="12"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto" HeightRequest="52">
                <Label Grid.Column="0" Text="🔍"
                       VerticalOptions="Center" HorizontalOptions="Center"
                       FontSize="17" TextColor="#AAAAAA" Margin="16,0,6,0"/>
                <Entry x:Name="SearchEntry"
                       Grid.Column="1"
                       Placeholder="Tìm kiếm quán ăn..."
                       PlaceholderColor="#BBBBBB"
                       ClearButtonVisibility="WhileEditing"
                       TextChanged="OnSearchTextChanged"
                       BackgroundColor="Transparent"
                       VerticalOptions="Center"
                       TextColor="#1A1A2E"/>
                <Border Grid.Column="2"
                        WidthRequest="34" HeightRequest="34"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="#1ABC9C"
                        Margin="0,0,9,0"
                        VerticalOptions="Center">
                    <Label Text="📍" FontSize="16"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ─── SEARCH RESULTS DROPDOWN ─── -->
        <Border x:Name="SearchResultsContainer"
                IsVisible="False"
                Margin="16,110,16,0"
                Padding="0"
                VerticalOptions="Start"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="0"
                BackgroundColor="White">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Opacity="0.12" Radius="12"/>
            </Border.Shadow>
            <CollectionView x:Name="SearchList"
                            MaximumHeightRequest="260"
                            SelectionMode="Single"
                            SelectionChanged="OnSearchResultSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="16,13" ColumnDefinitions="Auto, *, Auto"
                              ColumnSpacing="10">
                            <Label Grid.Column="0" Text="📍" FontSize="14"
                                   VerticalOptions="Center" TextColor="#1ABC9C"/>
                            <Label Grid.Column="1" Text="{Binding Name}"
                                   VerticalOptions="Center"
                                   TextColor="#1A1A2E"
                                   FontSize="14" FontAttributes="Bold"
                                   MaxLines="1" LineBreakMode="TailTruncation"/>
                            <Label Grid.Column="2" Text="{Binding DistanceStr}"
                                   VerticalOptions="Center"
                                   TextColor="#1ABC9C" FontSize="13"
                                   FontAttributes="Bold"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- ─── MY LOCATION BUTTON ─── -->
        <Border WidthRequest="48" HeightRequest="48"
                StrokeShape="RoundRectangle 24"
                StrokeThickness="0"
                BackgroundColor="White"
                VerticalOptions="Start"
                HorizontalOptions="End"
                Margin="0,116,16,0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Opacity="0.15" Radius="8"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnGoToMyLocationClicked"/>
            </Border.GestureRecognizers>
            <Label Text="🎯" FontSize="22"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- 🔥 NÂNG CẤP: BOTTOM RESTAURANT CARDS + 2 NÚT              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <CollectionView x:Name="RestaurantList"
                        VerticalOptions="End"
                        HeightRequest="175"
                        Margin="0,0,0,20"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border WidthRequest="310"
                            Margin="16,4,0,4"
                            Padding="0"
                            StrokeShape="RoundRectangle 16"
                            StrokeThickness="0"
                            BackgroundColor="White">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Opacity="0.10" Radius="12"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRestaurantTapped"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="104, *" RowDefinitions="*, Auto">
                            <!-- Thumbnail -->
                            <Border Grid.Column="0" Grid.RowSpan="2"
                                    StrokeShape="RoundRectangle 16,0,0,16"
                                    StrokeThickness="0">
                                <Image Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HeightRequest="170" WidthRequest="104"/>
                            </Border>

                            <!-- Info -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0"
                                                 Margin="12,10,12,0"
                                                 Spacing="3"
                                                 VerticalOptions="Start">
                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold" FontSize="14"
                                       TextColor="#1A1A2E"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="⭐" FontSize="11"
                                           VerticalOptions="Center" TextColor="#FFB800"/>
                                    <Label Text="{Binding AverageRating}"
                                           TextColor="#1A1A2E"
                                           FontAttributes="Bold" FontSize="12"/>
                                    <Label Text="·" TextColor="#CCCCCC" FontSize="12"/>
                                    <Label Text="{Binding DistanceStr}"
                                           TextColor="#1ABC9C"
                                           FontAttributes="Bold" FontSize="12"/>
                                </HorizontalStackLayout>
                                <Label Text="{Binding Description}"
                                       FontSize="11" TextColor="#636E72"
                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>

                            <!-- 🔥 MỚI: 2 nút Dẫn đường + Chi tiết -->
                            <Grid Grid.Column="1" Grid.Row="1"
                                  ColumnDefinitions="*, *"
                                  ColumnSpacing="6"
                                  Margin="12,4,12,10">

                                <!-- Nút Dẫn đường -->
                                <Button Grid.Column="0"
                                    Text="{Binding Path=[MapButtonNavigate], Source={x:Static loc:LocalizationResourceManager.Instance}}"
                                    HeightRequest="32"
                                    CornerRadius="16"
                                    BackgroundColor="#1ABC9C"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="0"
                                    Clicked="OnNavigateButtonClicked"
                                    CommandParameter="{Binding .}"/>

                                <!-- Nút Xem chi tiết -->
                                <Button Grid.Column="1"
                                    Text="{Binding Path=[MapButtonDetail], Source={x:Static loc:LocalizationResourceManager.Instance}}"
                                    HeightRequest="32"
                                    CornerRadius="16"
                                    BackgroundColor="#F5F6FA"
                                    TextColor="#1A1A2E"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    Padding="0"
                                    Clicked="OnDetailButtonClicked"
                                    CommandParameter="{Binding .}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
