<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:client.lib.model"
             xmlns:loc="clr-namespace:client.lib.core" 
             x:Class="client.lib.screens.home.DetailScreen"
             BackgroundColor="#F5F6FA"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <Grid HeightRequest="300">
                    <Border StrokeShape="RoundRectangle 0" StrokeThickness="0">
                        <CarouselView x:Name="ImgCarousel" Loop="False" IndicatorView="IndicatorView">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding .}" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                    </Border>
                    <BoxView VerticalOptions="End" HeightRequest="160">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#E0000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <BoxView VerticalOptions="Start" HeightRequest="100">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#88000000" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <Border WidthRequest="38" HeightRequest="38" StrokeShape="RoundRectangle 19" StrokeThickness="0" BackgroundColor="#44000000" VerticalOptions="Start" HorizontalOptions="Start" Margin="16,48,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="←" FontSize="18" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <IndicatorView x:Name="IndicatorView" IndicatorColor="#66FFFFFF" SelectedIndicatorColor="#1ABC9C" HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,14" IndicatorSize="8"/>
                </Grid>

                <Border BackgroundColor="White" StrokeShape="RoundRectangle 28,28,0,0" StrokeThickness="0" Padding="22,24,22,0" Margin="0,-24,0,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Radius="16" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" BackgroundColor="#E0E0E0" HorizontalOptions="Center" Margin="0,0,0,18"/>
                        <Label x:Name="LblName" FontSize="22" FontAttributes="Bold" TextColor="#1A1A2E" Margin="0,0,0,10"/>

                        <HorizontalStackLayout Spacing="8" Margin="0,0,0,10">
                            <Border HeightRequest="28" Padding="12,0" StrokeShape="RoundRectangle 14" StrokeThickness="0" BackgroundColor="#FFF8E6" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                    <Label Text="⭐" FontSize="13"/>
                                    <Label Text="{Binding AverageRating, StringFormat='{0:F1}'}" FontSize="14" FontAttributes="Bold" TextColor="#E67E22"/>
                                </HorizontalStackLayout>
                            </Border>
                            <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                                <Label Text="·" TextColor="#AAAAAA" FontSize="13" FontAttributes="Bold"/>
                                <Label Text="{Binding ReviewCount}" TextColor="#AAAAAA" FontSize="13"/>
                                <Label Text="{Binding Path=[HomeReviews], Source={x:Static loc:LocalizationResourceManager.Instance}}" TextColor="#AAAAAA" FontSize="13"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="6" Margin="0,0,0,18">
                            <Label Text="📍" FontSize="14" TextColor="#1ABC9C" VerticalOptions="Center"/>
                            <Label Text="{Binding Path=[DetailLocationDemo], Source={x:Static loc:LocalizationResourceManager.Instance}}" TextColor="#636E72" FontSize="14" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <Label x:Name="LblDescription" TextColor="#636E72" FontSize="14" LineHeight="1.6" Margin="0,0,0,22"/>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout BackgroundColor="#F5F6FA" Padding="22,20,22,20" Spacing="14">
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22" StrokeShape="RoundRectangle 2" StrokeThickness="0" BackgroundColor="#1ABC9C" VerticalOptions="Center"/>
                        <Label Text="{Binding Path=[DetailMenuTitle], Source={x:Static loc:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <StackLayout x:Name="ListFoodsContainer" Spacing="10"/>
                </VerticalStackLayout>

                <VerticalStackLayout BackgroundColor="White" Padding="22,22,22,22" Spacing="14">
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22" StrokeShape="RoundRectangle 2" StrokeThickness="0" BackgroundColor="#1ABC9C" VerticalOptions="Center"/>
                        <Label Text="{Binding Path=[DetailReviewTitle], Source={x:Static loc:LocalizationResourceManager.Instance}}" FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Border x:Name="BtnShowReviewInput" StrokeShape="RoundRectangle 14" StrokeThickness="1.5" Stroke="#E8F8F5" BackgroundColor="#F0FCF8" HeightRequest="48" Padding="16,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnShowReviewInputClicked"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Label Text="✏️" FontSize="16"/>
                            <Label Text="{Binding Path=[DetailWriteReview], Source={x:Static loc:LocalizationResourceManager.Instance}}" FontSize="14" FontAttributes="Bold" TextColor="#1ABC9C" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border x:Name="ReviewInputFrame" IsVisible="False" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#E8F8F5" BackgroundColor="#FAFFFE" Padding="18,16">
                        <VerticalStackLayout Spacing="14">
                            <Label Text="{Binding Path=[DetailYourReview], Source={x:Static loc:LocalizationResourceManager.Instance}}" FontSize="16" FontAttributes="Bold" TextColor="#1A1A2E" HorizontalOptions="Center"/>

                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label x:Name="Star1" Text="☆" FontSize="36" TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="1"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star2" Text="☆" FontSize="36" TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="2"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star3" Text="☆" FontSize="36" TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="3"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star4" Text="☆" FontSize="36" TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="4"/>
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label x:Name="Star5" Text="☆" FontSize="36" TextColor="#DDDDDD">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnStarTapped" CommandParameter="5"/>
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>

                            <Border StrokeShape="RoundRectangle 12" StrokeThickness="1.5" Stroke="#EFEFEF" BackgroundColor="White" Padding="12,4">
                                <Editor x:Name="CommentEditor" 
                                        Placeholder="{Binding Path=[DetailReviewPlaceholder], Source={x:Static loc:LocalizationResourceManager.Instance}}" 
                                        PlaceholderColor="#BBBBBB" MinimumHeightRequest="80" AutoSize="TextChanges" BackgroundColor="Transparent" TextColor="#1A1A2E" FontSize="14"/>
                            </Border>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Button Grid.Column="0" Text="{Binding Path=[DetailCancel], Source={x:Static loc:LocalizationResourceManager.Instance}}" Clicked="OnCancelReviewClicked" HeightRequest="46" CornerRadius="23" BackgroundColor="#F5F6FA" TextColor="#636E72" FontAttributes="Bold" FontSize="14"/>
                                <Button Grid.Column="1" Text="{Binding Path=[DetailSubmitReview], Source={x:Static loc:LocalizationResourceManager.Instance}}" Clicked="OnSubmitReviewClicked" HeightRequest="46" CornerRadius="23" BackgroundColor="#1ABC9C" TextColor="White" FontAttributes="Bold" FontSize="14"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <StackLayout x:Name="ListReviewsContainer" Spacing="10"/>
                </VerticalStackLayout>
                <BoxView HeightRequest="90" BackgroundColor="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="1" BackgroundColor="White" StrokeThickness="0" Padding="20,12,20,32">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.10" Radius="12" Offset="0,-3"/>
            </Border.Shadow>
            <Button x:Name="BtnFavorite" 
                    Text="{Binding Path=[DetailAddFavorite], Source={x:Static loc:LocalizationResourceManager.Instance}}" 
                    Clicked="OnFavoriteClicked" HeightRequest="54" CornerRadius="27" BackgroundColor="#FF4757" TextColor="White" FontAttributes="Bold" FontSize="16"/>
        </Border>

    </Grid>
</ContentPage>