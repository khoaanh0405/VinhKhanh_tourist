<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
    xmlns:loc="clr-namespace:client.lib.core"
    x:Class="client.lib.screens.qr.QrScannerPage"
    BackgroundColor="Black"
    Shell.NavBarIsVisible="False">

    <Grid>

        <zxing:CameraBarcodeReaderView
            x:Name="BarcodeReader"
            BarcodesDetected="OnBarcodesDetected"/>

        <!-- Top vignette -->
        <BoxView VerticalOptions="Start" HeightRequest="160" Opacity="0.75">
            <BoxView.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="#FF000000" Offset="0.0"/>
                    <GradientStop Color="Transparent" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Bottom vignette -->
        <BoxView VerticalOptions="End" HeightRequest="260" Opacity="0.80">
            <BoxView.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Color="Transparent" Offset="0.0"/>
                    <GradientStop Color="#FF000000" Offset="1.0"/>
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Back button -->
        <Border WidthRequest="38" HeightRequest="38"
                StrokeShape="RoundRectangle 19" StrokeThickness="0"
                BackgroundColor="#44FFFFFF"
                VerticalOptions="Start" HorizontalOptions="Start"
                Margin="20,52,0,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackTapped"/>
            </Border.GestureRecognizers>
            <Label Text="←" FontSize="18" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- Page title -->
        <Label Text="{loc:Translate QrPageTitle}"
               TextColor="White" FontSize="17" FontAttributes="Bold"
               HorizontalOptions="Center" VerticalOptions="Start"
               Margin="0,56,0,0"/>

        <!-- Scanning frame -->
        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
            <Grid WidthRequest="240" HeightRequest="240">

                <Border StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="#0AFFFFFF"/>

                <Border x:Name="ScannerOverlay"
                        StrokeShape="RoundRectangle 16" StrokeThickness="2"
                        Stroke="#1ABC9C" BackgroundColor="Transparent"/>

                <!-- Corner TL -->
                <BoxView WidthRequest="28" HeightRequest="4" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="Start" HorizontalOptions="Start"/>
                <BoxView WidthRequest="4" HeightRequest="28" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="Start" HorizontalOptions="Start"/>
                <!-- Corner TR -->
                <BoxView WidthRequest="28" HeightRequest="4" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="Start" HorizontalOptions="End"/>
                <BoxView WidthRequest="4" HeightRequest="28" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="Start" HorizontalOptions="End"/>
                <!-- Corner BL -->
                <BoxView WidthRequest="28" HeightRequest="4" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="End" HorizontalOptions="Start"/>
                <BoxView WidthRequest="4" HeightRequest="28" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="End" HorizontalOptions="Start"/>
                <!-- Corner BR -->
                <BoxView WidthRequest="28" HeightRequest="4" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="End" HorizontalOptions="End"/>
                <BoxView WidthRequest="4" HeightRequest="28" BackgroundColor="#1ABC9C" CornerRadius="2" VerticalOptions="End" HorizontalOptions="End"/>

                <BoxView HeightRequest="2" BackgroundColor="#881ABC9C"
                         VerticalOptions="Center" HorizontalOptions="Fill" Margin="12,0"/>
            </Grid>
        </VerticalStackLayout>

        <!-- Bottom guide text -->
        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="Center"
                             Spacing="10" Margin="0,0,0,80">
            <Border HeightRequest="36" Padding="16,0"
                    StrokeShape="RoundRectangle 18" StrokeThickness="0"
                    BackgroundColor="#331ABC9C" HorizontalOptions="Center">
                <Label Text="{loc:Translate QrGuideText}"
                       TextColor="White" FontSize="14" FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="{loc:Translate QrAutoDetect}"
                   TextColor="#AAAAAA" FontSize="13" HorizontalOptions="Center"/>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
