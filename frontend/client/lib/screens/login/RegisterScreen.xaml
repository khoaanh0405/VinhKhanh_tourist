<?xml version="1.0" encoding="utf-8" ?>
<!--
  RegisterScreen.xaml  —  Theme: Teal Explorer
  Code-behind: RegisterScreen.xaml.cs (không thay đổi)
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="client.lib.screens.login.RegisterScreen"
             BackgroundColor="White"
             Shell.NavBarIsVisible="False">

    <Grid>
        <Image Source="vinh_khanh_night.jpg" Aspect="AspectFill"/>
        <BoxView BackgroundColor="#55000000"/>

        <!-- Back button -->
        <Border WidthRequest="36" HeightRequest="36"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                BackgroundColor="#33FFFFFF"
                VerticalOptions="Start" HorizontalOptions="Start"
                Margin="20,48,0,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked"/>
            </Border.GestureRecognizers>
            <Label Text="←" FontSize="18" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- Close button -->
        <Border WidthRequest="36" HeightRequest="36"
                StrokeShape="RoundRectangle 18"
                StrokeThickness="0"
                BackgroundColor="#33FFFFFF"
                VerticalOptions="Start" HorizontalOptions="End"
                Margin="0,48,20,0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBackClicked"/>
            </Border.GestureRecognizers>
            <Label Text="✕" FontSize="16" TextColor="White"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <ScrollView>
            <VerticalStackLayout VerticalOptions="EndAndExpand"
                                 Padding="24,0,24,0"
                                 Spacing="0">

                <BoxView HeightRequest="80" BackgroundColor="Transparent"/>

                <!-- Brand area -->
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center"
                                     Margin="0,0,0,28">
                    <Label Text="Tạo Tài Khoản ✨"
                           TextColor="White" FontSize="26"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Tham gia cộng đồng ẩm thực Vĩnh Khánh"
                           TextColor="#CCCCCC" FontSize="13"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>

                <!-- Card form -->
                <Border StrokeShape="RoundRectangle 24"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="24,28">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.20" Radius="20" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">

                        <Label Text="Thông tin đăng ký"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#1A1A2E"
                               Margin="0,0,0,4"/>

                        <!-- Display Name -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="😊"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="DisplayNameEntry"
                                       Grid.Column="1"
                                       Placeholder="Tên hiển thị (VD: Foodie99)"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Username -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="👤"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="UsernameEntry"
                                       Grid.Column="1"
                                       Placeholder="Tên đăng nhập"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <Border HeightRequest="50" StrokeShape="RoundRectangle 8" Stroke="#EEEEEE" BackgroundColor="#F8F9FA" Padding="15,0" Margin="0,0,0,15">
                            <Entry x:Name="EmailEntry" 
                                   Placeholder="Địa chỉ Email" 
                                   Keyboard="Email" 
                                   PlaceholderColor="#AAAAAA" 
                                   TextColor="#1A1A2E" 
                                   FontSize="15" 
                                   VerticalOptions="Center"/>
                        </Border>

                        <!-- Password -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="🔒"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="PasswordEntry"
                                       Grid.Column="1"
                                       Placeholder="Mật khẩu"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Confirm Password -->
                        <Border StrokeShape="RoundRectangle 14"
                                StrokeThickness="1.5" Stroke="#EFEFEF"
                                BackgroundColor="#F8F9FA"
                                HeightRequest="52" Padding="14,0">
                            <Grid ColumnDefinitions="28, *">
                                <Label Grid.Column="0" Text="🔐"
                                       VerticalOptions="Center" FontSize="16"/>
                                <Entry x:Name="ConfirmPasswordEntry"
                                       Grid.Column="1"
                                       Placeholder="Xác nhận mật khẩu"
                                       PlaceholderColor="#BBBBBB"
                                       TextColor="#1A1A2E"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Register button -->
                        <Button Text="ĐĂNG KÝ NGAY 🚀"
                                Clicked="OnRegisterClicked"
                                HeightRequest="54"
                                CornerRadius="27"
                                FontAttributes="Bold" FontSize="15"
                                TextColor="White"
                                BackgroundColor="#1ABC9C"
                                Margin="0,8,0,0"/>

                        <!-- Login link -->
                        <HorizontalStackLayout HorizontalOptions="Center"
                                               Spacing="5" Margin="0,4,0,0">
                            <Label Text="Đã có tài khoản?"
                                   TextColor="#636E72" VerticalOptions="Center" FontSize="14"/>
                            <Label Text="Đăng nhập"
                                   TextColor="#1ABC9C"
                                   FontAttributes="Bold"
                                   TextDecorations="Underline"
                                   VerticalOptions="Center" FontSize="14">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnGoToLoginTapped"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="30" BackgroundColor="Transparent"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
