<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="client.lib.screens.poi.POIDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:client.lib.core"
    BackgroundColor="#F5F6FA"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*, Auto">

        <ActivityIndicator x:Name="LoadingIndicator"
                           IsVisible="False" IsRunning="False"
                           Color="#1ABC9C"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           Grid.RowSpan="2" ZIndex="10" />

        <ScrollView x:Name="ContentScrollView" Grid.Row="0">
            <VerticalStackLayout Spacing="0">

                <!-- ═══ HERO IMAGE ═══ -->
                <Grid HeightRequest="300">
                    <Border StrokeShape="RoundRectangle 0" StrokeThickness="0">
                        <CarouselView x:Name="ImgCarousel" Loop="False" IndicatorView="IndicatorView">
                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding .}" Aspect="AspectFill"
                                           HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>
                    </Border>

                    <BoxView VerticalOptions="End" HeightRequest="160">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.0"/>
                                <GradientStop Color="#E0000000" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <BoxView VerticalOptions="Start" HeightRequest="100">
                        <BoxView.Background>
                            <LinearGradientBrush EndPoint="0,1">
                                <GradientStop Color="#88000000" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Nút Back -->
                    <Border WidthRequest="38" HeightRequest="38"
                            StrokeShape="RoundRectangle 19" StrokeThickness="0"
                            BackgroundColor="#44000000"
                            VerticalOptions="Start" HorizontalOptions="Start"
                            Margin="16,48,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="←" FontSize="18" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <IndicatorView x:Name="IndicatorView"
                                   IndicatorColor="#66FFFFFF"
                                   SelectedIndicatorColor="#1ABC9C"
                                   HorizontalOptions="Center"
                                   VerticalOptions="End"
                                   Margin="0,0,0,14"
                                   IndicatorSize="8"/>
                </Grid>

                <!-- ═══ CONTENT CARD ═══ -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 28,28,0,0"
                        StrokeThickness="0"
                        Padding="22,24,22,0"
                        Margin="0,-24,0,0">
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Radius="16" Offset="0,-4"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <BoxView WidthRequest="40" HeightRequest="4"
                                 CornerRadius="2" BackgroundColor="#E0E0E0"
                                 HorizontalOptions="Center" Margin="0,0,0,18"/>

                        <Label x:Name="LblName"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1A1A2E" Margin="0,0,0,10"/>

                        <Label x:Name="LblDescription"
                               FontSize="14" TextColor="#636E72"
                               LineHeight="1.6" Margin="0,0,0,22"/>

                        <!-- ═══ AUDIO CONTROLS ═══ -->
                        <Border StrokeShape="RoundRectangle 16"
                                StrokeThickness="1.5" Stroke="#E8F8F5"
                                BackgroundColor="#F0FBF8"
                                Padding="16,14" Margin="0,0,0,22">
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        WidthRequest="42" HeightRequest="42"
                                        StrokeShape="RoundRectangle 21" StrokeThickness="0"
                                        BackgroundColor="#1ABC9C" VerticalOptions="Center">
                                    <Label Text="🎧" FontSize="18"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{loc:Translate DetailAudioTitle}"
                                           FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E"/>
                                    <Label x:Name="LblAudioStatus"
                                           Text="{loc:Translate DetailAudioReady}"
                                           FontSize="12" TextColor="#636E72"/>
                                </VerticalStackLayout>

                                <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                    <Border WidthRequest="36" HeightRequest="36"
                                            StrokeShape="RoundRectangle 18" StrokeThickness="0"
                                            BackgroundColor="#1ABC9C">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnMainAudioButtonClicked"/>
                                        </Border.GestureRecognizers>
                                        <Label x:Name="LblPlayIcon" Text="▶" FontSize="15"
                                               TextColor="White"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══ MENU LIST ═══ -->
                <VerticalStackLayout BackgroundColor="#F5F6FA"
                                     Padding="22,20,22,20" Spacing="14">
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,4">
                        <Border WidthRequest="4" HeightRequest="22"
                                StrokeShape="RoundRectangle 2" StrokeThickness="0"
                                BackgroundColor="#1ABC9C" VerticalOptions="Center"/>
                        <Label Text="{loc:Translate Detail_MenuTitle}"
                               FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <StackLayout x:Name="FoodsContainer" Spacing="10"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="30" BackgroundColor="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
