<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:client.lib.model"
    xmlns:vm="clr-namespace:client.lib.screens.home"
    xmlns:widgets="clr-namespace:client.lib.widgets"
    xmlns:loc="clr-namespace:client.lib.core"
    x:Class="client.lib.screens.HomePage"
    BackgroundColor="White"
    x:DataType="vm:HomeViewModel"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Padding="20,52,20,16" BackgroundColor="White" ColumnSpacing="10">
            <Border x:Name="ProfileIconBorder" Grid.Column="0" WidthRequest="46" HeightRequest="46"
                StrokeShape="RoundRectangle 23" StrokeThickness="0"
                BackgroundColor="#2ECC71" VerticalOptions="Center">
                <Path x:Name="ProfileIconPath"
                      Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                      Fill="White" HorizontalOptions="Center" VerticalOptions="Center" Aspect="Uniform" HeightRequest="24" WidthRequest="24"/>
            </Border>

            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center" Spacing="2">
                <Label Text="{loc:Translate HomeGreeting}" FontSize="12" TextColor="#636E72"/>
                <Label Text="{loc:Translate ExploreTitle}" FontSize="17" FontAttributes="Bold" TextColor="#1A1A2E"/>
            </VerticalStackLayout>

            <Border Grid.Column="2" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" VerticalOptions="Center">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsAutoNarrationEnabled}" Value="True">
                        <Setter Property="BackgroundColor" Value="#E8F8F5"/>
                    </DataTrigger>
                    <DataTrigger TargetType="Border" Binding="{Binding IsAutoNarrationEnabled}" Value="False">
                        <Setter Property="BackgroundColor" Value="#F5F6FA"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ToggleAutoNarrationCommand}"/>
                </Border.GestureRecognizers>
                <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="18">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsAutoNarrationEnabled}" Value="True">
                            <Setter Property="Text" Value="🎧"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsAutoNarrationEnabled}" Value="False">
                            <Setter Property="Text" Value="🔇"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

            <Border Grid.Column="3" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="#F5F6FA" VerticalOptions="Center">
                <Label Text="🔔" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Pois}" SelectionMode="None">
            <CollectionView.Margin>
                <OnPlatform x:TypeArguments="Thickness">
                    <On Platform="iOS, Android" Value="0,0,0,0"/>
                </OnPlatform>
            </CollectionView.Margin>

            <CollectionView.Header>
                <VerticalStackLayout Padding="20,4,20,0" Spacing="0">
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                        <Label Grid.Column="0"
                               Text="{loc:Translate TopFavorites}"
                               FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
                    </Grid>

                    <CarouselView ItemsSource="{Binding FeaturedPois}" HeightRequest="290" HorizontalScrollBarVisibility="Never" Loop="False">
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Grid Padding="10,5,20,30">
                                    <Border Padding="0" StrokeShape="RoundRectangle 16" StrokeThickness="0" BackgroundColor="White">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Opacity="0.15" Radius="15" Offset="0,8"/>
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnNavigateToDetail" CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="*, Auto">
                                            <Border Grid.Row="0" StrokeShape="RoundRectangle 16,16,0,0" StrokeThickness="0" Margin="0">
                                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                            </Border>
                                            <VerticalStackLayout Grid.Row="1" Padding="12,12,12,14">
                                                <Label Text="{Binding Name}" TextColor="#1A1A2E" FontAttributes="Bold" FontSize="16" MaxLines="1" LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,24,0,14">
                        <HorizontalStackLayout Grid.Column="0" Spacing="6" VerticalOptions="Center">
                            <Label Text="📍" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="{loc:Translate AllLocations}"
                                   FontSize="18" FontAttributes="Bold" TextColor="#1A1A2E" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Grid.Column="1" Text="{loc:Translate HomeSort}" FontSize="13" TextColor="#1ABC9C" VerticalOptions="Center"/>
                    </Grid>
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:POI">
                    <Border Margin="20,0,20,10" Padding="10" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#DDDDDD" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavigateToDetail" CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="80" HeightRequest="80" StrokeShape="RoundRectangle 12" StrokeThickness="0" VerticalOptions="Center">
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Padding="12,0,0,0" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="15" TextColor="#1A1A2E" MaxLines="1" LineBreakMode="TailTruncation"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <BoxView HeightRequest="20" BackgroundColor="Transparent"/>
            </CollectionView.Footer>
        </CollectionView>

        <widgets:AudioPlayerMiniView Grid.Row="1" VerticalOptions="End" Margin="20,0,20,16"/>

    </Grid>
</ContentPage>
