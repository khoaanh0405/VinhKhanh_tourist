<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:client.lib.model"
             x:Class="client.lib.widgets.FoodItemView"
             x:DataType="models:Food">

    <Border StrokeShape="RoundRectangle 8"
            StrokeThickness="0"
            BackgroundColor="White"
            Padding="12"
            Margin="0,0,0,12"
            Shadow="{Shadow Brush=Black, Offset='0,2', Opacity=0.2, Radius=4}">

        <Grid ColumnDefinitions="80, 12, *">
            <Border Grid.Column="0" 
                    HeightRequest="80" 
                    WidthRequest="80"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="#FFC107">
                <Image Source="{Binding ImageUrl}"
                       Aspect="AspectFill">
                </Image>
            </Border>

            <VerticalStackLayout Grid.Column="2" Spacing="4">
                <Label Text="{Binding Name}" 
                       FontAttributes="Bold" 
                       FontSize="16"/>

                <Label Text="{Binding Description}" 
                       FontSize="13" 
                       TextColor="Gray"
                       MaxLines="2" 
                       LineBreakMode="TailTruncation"/>

                <Label Text="{Binding Price, StringFormat='{0:N0}đ'}" 
                       FontSize="16" 
                       FontAttributes="Bold"
                       TextColor="#FF5722"/>
            </VerticalStackLayout>
        </Grid>
    </Border>
</ContentView>