<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:client.lib.model"
             x:Class="client.lib.widgets.RestaurantCardView"
             x:DataType="models:Restaurant">

    <Border Margin="0,0,0,16"
            StrokeShape="RoundRectangle 12"
            StrokeThickness="0"
            BackgroundColor="White"
            Shadow="{Shadow Brush=Black, Opacity=0.2, Radius=2}">

        <Grid RowDefinitions="140, Auto">
            <Grid Grid.Row="0" BackgroundColor="#FFF3E0">
                <Image Source="restaurant_menu_icon.png" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center"
                       WidthRequest="56" HeightRequest="56"/>
            </Grid>

            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                <Grid ColumnDefinitions="*, Auto">
                    <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"/>
                    <ImageButton Source="favorite_border.png" HeightRequest="24"/>
                </Grid>

                <HorizontalStackLayout Spacing="4">
                    <Label Text="📍" FontSize="12" TextColor="Gray"/>
                    <Label Text="{Binding Address}" FontSize="12" TextColor="Gray" LineBreakMode="TailTruncation"/>
                </HorizontalStackLayout>

                <Label Text="{Binding Description}" FontSize="13" MaxLines="2" LineBreakMode="TailTruncation"/>

                <Border HorizontalOptions="Start" 
                        BackgroundColor="#EEEEEE" 
                        StrokeShape="RoundRectangle 16" 
                        Padding="8,4" 
                        Margin="0,4,0,0">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="🍔" FontSize="12"/>
                        <Label Text="{Binding Foods.Count, StringFormat='{0} món ăn'}" FontSize="12"/>
                    </HorizontalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>

        <Border.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnRestaurantTapped"/>
        </Border.GestureRecognizers>
    </Border>
</ContentView>