@page "/restaurants/edit/{Id:int}"
@attribute [Authorize(Roles = "Admin, Manager")]
@using System.Net.Http.Headers
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.IRestaurantService RestaurantService
@inject VinhKhanh.WebAdmin.Services.INarrationService NarrationService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject VinhKhanh.WebAdmin.Services.ILanguageService LanguageService
@inject HttpClient Http

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-pencil-square"></i> Cập nhật Quán ăn</h3>
    <button class="btn btn-outline-secondary fw-bold" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Quay lại</button>
</div>

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (editingRes == null)
{
    <div class="alert alert-danger">Không tìm thấy thông tin quán ăn!</div>
}
else
{
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-white pt-3 pb-0 border-bottom">
            <ul class="nav nav-tabs" id="editTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "info" ? "active fw-bold text-primary" : "text-muted")" @onclick='() => activeTab = "info"'>
                        <i class="bi bi-info-circle"></i> Thông tin chung
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "audio" ? "active fw-bold text-primary" : "text-muted")" @onclick='LoadNarrations'>
                        <i class="bi bi-mic"></i> Thuyết minh AI (TTS)
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "images" ? "active fw-bold text-primary" : "text-muted")" @onclick='LoadImages'>
                        <i class="bi bi-images"></i> Quản lý Hình ảnh
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-4">
            @if (activeTab == "info")
            {
                <EditForm Model="editingRes" OnValidSubmit="HandleSubmitInfo">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên Quán ăn</label>
                            <InputText @bind-Value="editingRes.Name" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <InputText @bind-Value="editingRes.Address" class="form-control" required />
                        </div>
                    </div>
                    
                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary fw-bold px-5 py-2"><i class="bi bi-save"></i> Lưu Thông Tin</button>
                    </div>
                </EditForm>
            }

            @if (activeTab == "audio")
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-primary fw-bold"><i class="bi bi-megaphone"></i> Text-to-Speech (Thuyết minh tự động)</h5>
                    <div>
                        <button class="btn btn-sm btn-info text-white fw-bold me-2 shadow-sm" @onclick="AutoTranslateAudio" disabled="@isTranslatingAudio">
                            <i class="bi bi-magic"></i> @(isTranslatingAudio ? "Đang dịch..." : "Dịch tự động bằng AI")
                        </button>

                        <button class="btn btn-sm btn-success fw-bold shadow-sm" @onclick="OpenAddNarrationModal">
                            <i class="bi bi-plus-circle"></i> Thêm thủ công
                        </button>
                    </div>
                </div>
                <div class="alert alert-light border small text-muted">
                    <i class="bi bi-info-circle"></i> Hãy tạo một bản Thuyết minh <strong>Tiếng Việt (vi)</strong> trước, sau đó ấn <strong>Dịch tự động</strong> để AI tạo ra các bản đọc cho ngôn ngữ còn lại.
                </div>

                <table class="table table-bordered align-middle shadow-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Ngôn ngữ</th>
                            <th>Nội dung đọc (Text)</th>
                            <th>Giọng AI</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (narrations != null && narrations.Any())
                        {
                            @foreach (var n in narrations)
                            {
                                <tr>
                                    <td class="fw-bold text-uppercase text-primary">@n.LanguageCode</td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 400px;" title="@n.Text">@n.Text</div>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark"><i class="bi bi-robot"></i> @n.VoiceName</span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditNarrationModal(n)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteNarration(n.NarrationId)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Chưa có bài thuyết minh nào.</td></tr>
                        }
                    </tbody>
                </table>
            }

            @if (activeTab == "images")
            {
                <div class="d-flex justify-content-between align-items-center mb-3 mt-3">
                    <h5 class="text-primary fw-bold"><i class="bi bi-images"></i> Thư viện ảnh của Quán</h5>
                    <div class="btn btn-success position-relative overflow-hidden shadow-sm fw-bold">
                        <i class="bi bi-cloud-upload"></i> Thêm ảnh mới
                        <InputFile OnChange="UploadImage" accept="image/*" multiple class="position-absolute top-0 start-0 w-100 h-100 opacity-0" style="cursor: pointer;" />
                    </div>
                </div>

                @if (isUploadingImage)
                {
                    <div class="alert alert-info text-center"><span class="spinner-border spinner-border-sm me-2"></span> Đang tải ảnh lên Cloudinary...</div>
                }

                <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4 mt-2">
                    @if (poiImages != null && poiImages.Any())
                    {
                        @foreach (var img in poiImages)
                        {
                            <div class="col">
                                <div class="card h-100 shadow-sm border-0 position-relative">
                                    <img src="@img.ImageUrl" class="card-img-top" alt="Hình ảnh quán" style="height: 200px; object-fit: cover; border-radius: 8px;">
                                    <button class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 rounded-circle" style="width: 32px; height: 32px;" @onclick="() => DeleteImage(img.ImageId)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center text-muted py-4">Chưa có hình ảnh nào. Bạn có thể chọn nhiều ảnh cùng lúc.</div>
                    }
                </div>
            }
        </div>
    </div>
}

@if (showNarrationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-primary">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">@(isEditNarration ? "Sửa Thuyết minh" : "Thêm Thuyết minh")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showNarrationModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngôn ngữ</label>
                        <select class="form-select" @bind="editingNarration.LanguageCode" disabled="@isEditNarration">
                            @if (availableLanguages != null && availableLanguages.Any())
                            {
                                @foreach (var lang in availableLanguages)
                                {
                                    <option value="@lang.LanguageCode">@lang.LanguageName (@lang.LanguageCode)</option>
                                }
                            }
                            else
                            {
                                <option value="vi">Tiếng Việt (vi) - Mặc định</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung thuyết minh (Text để AI đọc)</label>
                        <textarea class="form-control" rows="5" @bind="editingNarration.Text"></textarea>
                    </div>

                    <div class="mb-3 bg-light p-3 rounded border">
                        <label class="form-label fw-bold text-info"><i class="bi bi-robot"></i> Giọng đọc AI (Voice Name)</label>
                        <input type="text" class="form-control" @bind="editingNarration.VoiceName" placeholder="VD: vi-VN, en-US, ko-KR..." />
                        <small class="text-muted fst-italic">Hệ thống sẽ tự động tổng hợp giọng nói dựa trên mã này.</small>
                    </div>

                    <div class="text-end mt-4">
                        <button class="btn btn-secondary" @onclick="() => showNarrationModal = false">Hủy</button>
                        <button class="btn btn-primary fw-bold px-4 ms-2" @onclick="SaveNarration" disabled="@isUploading">
                            @(isUploading ? "Đang lưu..." : "Lưu dữ liệu")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool isLoading = true;
    private string activeTab = "info";
    private Restaurant? editingRes;

    private List<NarrationDto> narrations = new();
    private bool showNarrationModal = false;
    private bool isEditNarration = false;
    private NarrationDto editingNarration = new();

    private List<LanguageDto> availableLanguages = new();
    private bool isTranslatingAudio = false;

    private class PoiImageDto { public int ImageId { get; set; } public string ImageUrl { get; set; } = ""; }
    private List<PoiImageDto> poiImages = new();
    private bool isUploadingImage = false;

    protected override async Task OnInitializedAsync()
    {
        editingRes = await RestaurantService.GetByIdAsync(Id);
        availableLanguages = await LanguageService.GetAllAsync();
        isLoading = false;
    }

    private async Task HandleSubmitInfo()
    {
        if (editingRes == null) return;
        var req = new UpdateRestaurantReq(editingRes.Name, editingRes.Address ?? "", editingRes.PoiId);
        bool success = await RestaurantService.UpdateAsync(Id, req);
        if (success) { await JS.InvokeVoidAsync("alert", "Cập nhật thành công!"); GoBack(); }
        else { await JS.InvokeVoidAsync("alert", "Lỗi cập nhật!"); }
    }

    private void GoBack() => Navigation.NavigateTo("/restaurants");

    private async Task LoadImages()
    {
        activeTab = "images";
        if (editingRes != null)
        {
            try
            {
                poiImages = await Http.GetFromJsonAsync<List<PoiImageDto>>($"api/PoiImages/{editingRes.PoiId}") ?? new();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine("Lỗi tải ảnh: " + ex.Message);
            }
        }
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        if (editingRes == null) return;
        isUploadingImage = true;
        try
        {
            using var content = new MultipartFormDataContent();
            content.Add(new StringContent(editingRes.PoiId.ToString()), "poiId");
            foreach (var file in e.GetMultipleFiles(maximumFileCount: 10))
            {
                var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
                fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "files", file.Name);
            }

            var response = await Http.PostAsync("api/PoiImages/upload-multiple", content);
            if (response.IsSuccessStatusCode)
            {
                await LoadImages();
                await JS.InvokeVoidAsync("alert", "Upload thành công rực rỡ!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Báo lỗi từ Server: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Lỗi code UI: " + ex.Message);
        }
        finally
        {
            isUploadingImage = false;
        }
    }

    private async Task DeleteImage(int imageId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa ảnh này khỏi hệ thống?"))
        {
            var response = await Http.DeleteAsync($"api/PoiImages/{imageId}");
            if (response.IsSuccessStatusCode)
            {
                await LoadImages();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Lỗi khi xóa ảnh!");
            }
        }
    }

    private async Task AutoTranslateAudio()
    {
        var viNarration = narrations.FirstOrDefault(n => n.LanguageCode == "vi");
        if (viNarration == null || string.IsNullOrWhiteSpace(viNarration.Text))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng tạo một bản Thuyết minh bằng Tiếng Việt (vi) trước để làm mẫu dịch!");
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", "Hệ thống sẽ dùng bản Tiếng Việt để dịch tự động bài thuyết minh sang các ngôn ngữ khác. Chắc chắn chứ?")) return;
        isTranslatingAudio = true;
        try
        {
            var response = await Http.PostAsJsonAsync($"api/Translate/auto-audio/{editingRes!.PoiId}", new { Text = viNarration.Text });
            if (response.IsSuccessStatusCode)
            {
                await LoadNarrations();
                await JS.InvokeVoidAsync("alert", "Tự động tạo bản thuyết minh thành công!");
            }
            else await JS.InvokeVoidAsync("alert", "Lỗi dịch tự động từ Server!");
        }
        catch { await JS.InvokeVoidAsync("alert", "Lỗi kết nối máy chủ!"); }

        isTranslatingAudio = false;
    }

    private async Task LoadNarrations()
    {
        activeTab = "audio";
        if (editingRes != null)
        {
            narrations = await NarrationService.GetByPoiIdAsync(editingRes.PoiId);
            StateHasChanged();
        }
    }

    private void OpenAddNarrationModal()
    {
        isEditNarration = false;
        editingNarration = new NarrationDto { PoiId = editingRes!.PoiId, LanguageCode = "vi", VoiceName = "vi-VN" };
        showNarrationModal = true;
    }

    private void OpenEditNarrationModal(NarrationDto n)
    {
        isEditNarration = true;
        editingNarration = new NarrationDto { NarrationId = n.NarrationId, PoiId = n.PoiId, LanguageCode = n.LanguageCode, Text = n.Text, VoiceName = n.VoiceName };
        showNarrationModal = true;
    }

    private bool isUploading = false;

    private async Task SaveNarration()
    {
        if (!isEditNarration)
        {
            bool isExisted = narrations.Any(n => n.LanguageCode.ToLower() == editingNarration.LanguageCode.ToLower());
            if (isExisted)
            {
                await JS.InvokeVoidAsync("alert", $"Lỗi: Ngôn ngữ '{editingNarration.LanguageCode}' này đã có bản dịch. Vui lòng xóa bản cũ trước khi thêm mới hoặc chọn ngôn ngữ khác!");
                return;
            }
        }

        isUploading = true;
        try
        {
            int currentNarrationId = editingNarration.NarrationId;
            bool isSuccess;
            string serverMsg;

            if (isEditNarration)
            {
                var result = await NarrationService.UpdateAsync(currentNarrationId, new UpdateNarrationDto(editingNarration.Text, editingNarration.VoiceName));
                isSuccess = result.Success;
                serverMsg = result.Message;
            }
            else
            {
                var result = await NarrationService.CreateAsync(new CreateNarrationDto(editingNarration.PoiId, editingNarration.LanguageCode, editingNarration.Text, editingNarration.VoiceName));
                isSuccess = result.Success;
                serverMsg = result.Message;
            }

            if (isSuccess)
            {
                showNarrationModal = false;
                await LoadNarrations();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Server báo lỗi: " + serverMsg);
            }
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task DeleteNarration(int narrationId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Xóa bài thuyết minh này?"))
        {
            if (await NarrationService.DeleteAsync(narrationId)) await LoadNarrations();
        }
    }
}