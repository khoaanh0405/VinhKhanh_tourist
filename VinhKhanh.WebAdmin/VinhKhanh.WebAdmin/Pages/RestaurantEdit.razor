@page "/restaurants/edit/{Id:int}"
@attribute [Authorize(Roles = "Admin, Manager")]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.IRestaurantService RestaurantService
@inject VinhKhanh.WebAdmin.Services.INarrationService NarrationService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject VinhKhanh.WebAdmin.Services.IPoiTranslationService PoiTransService
@inject VinhKhanh.WebAdmin.Services.ILanguageService LanguageService
<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-pencil-square"></i> Cập nhật Quán ăn & Địa điểm</h3>
    <button class="btn btn-outline-secondary fw-bold" @onclick="GoBack"><i class="bi bi-arrow-left"></i> Quay lại</button>
</div>

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else if (editingRes == null)
{
    <div class="alert alert-danger">Không tìm thấy thông tin quán ăn!</div>
}
else
{
    <div class="card shadow-sm border-primary">
        <div class="card-header bg-white pt-3 pb-0 border-bottom">
            <ul class="nav nav-tabs" id="editTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "info" ? "active fw-bold text-primary" : "text-muted")" @onclick='() => activeTab = "info"'>
                        <i class="bi bi-info-circle"></i> Thông tin chung
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "audio" ? "active fw-bold text-primary" : "text-muted")" @onclick='LoadNarrations'>
                        <i class="bi bi-mic"></i> Âm thanh / Thuyết minh
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(activeTab == "intro" ? "active fw-bold text-primary" : "text-muted")" @onclick='LoadPoiTranslations'>
                        <i class="bi bi-translate"></i> Giới thiệu đa ngôn ngữ
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-4">
            @if (activeTab == "info")
            {
                <EditForm Model="editingRes" OnValidSubmit="HandleSubmitInfo">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên Quán ăn</label>
                            <InputText @bind-Value="editingRes.Name" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <InputText @bind-Value="editingRes.Address" class="form-control" required />
                        </div>
                    </div>
                    <div class="row bg-light p-3 rounded mb-4 border">
                        <div class="col-md-6 mb-2">
                            <label class="form-label fw-bold">Vĩ độ (Latitude)</label>
                            <InputNumber @bind-Value="editingRes.Latitude" class="form-control" step="any" required />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label fw-bold">Kinh độ (Longitude)</label>
                            <InputNumber @bind-Value="editingRes.Longitude" class="form-control" step="any" required />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Mô tả Quán</label>
                        <InputTextArea @bind-Value="editingRes.Description" class="form-control" rows="4" />
                    </div>
                    <div class="text-end">
                        <button type="submit" class="btn btn-primary fw-bold px-5 py-2"><i class="bi bi-save"></i> Lưu Thông Tin</button>
                    </div>
                </EditForm>
            }
            @if (activeTab == "intro")
            {
                <div class="d-flex justify-content-between mb-3 mt-3">
                    <h5 class="text-primary fw-bold"><i class="bi bi-chat-left-text"></i> Bản dịch giới thiệu quán</h5>
                    <button class="btn btn-sm btn-success fw-bold" @onclick="() => OpenPoiTransModal()">
                        <i class="bi bi-plus-circle"></i> Thêm/Sửa bản dịch
                    </button>
                </div>
                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th width="150">Ngôn ngữ</th>
                            <th>Nội dung mô tả</th>
                            <th width="100" class="text-end">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in poiTranslations)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@t.LanguageCode.ToUpper()</td>
                                <td><div class="text-truncate" style="max-width: 600px;">@t.Description</div></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenPoiTransModal(t)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePoiTrans(t.TranslationId)"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            @if (activeTab == "audio")
            {
                <div class="d-flex justify-content-between mb-3">
                    <h5 class="text-primary fw-bold"><i class="bi bi-megaphone"></i> Danh sách Thuyết minh</h5>
                    <button class="btn btn-sm btn-success fw-bold" @onclick="OpenAddNarrationModal">
                        <i class="bi bi-plus-circle"></i> Thêm Bản dịch
                    </button>
                </div>

                <table class="table table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Ngôn ngữ</th>
                            <th>Nội dung đọc (Text)</th>
                            <th>Chế độ</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (narrations != null && narrations.Any())
                        {
                            @foreach (var n in narrations)
                            {
                                <tr>
                                    <td class="fw-bold text-uppercase text-primary">@n.LanguageCode</td>
                                    <td>
                                        <div class="text-truncate" style="max-width: 400px;" title="@n.Text">@n.Text</div>
                                    </td>
                                    <td>
                                        @if (n.UseAudioFile)
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-file-music"></i> File âm thanh</span>
                                        }
                                        else
                                        {

                                            <span class="badge bg-info text-dark"><i class="bi bi-robot"></i> Đọc AI (@n.VoiceName)</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenEditNarrationModal(n)"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="() => DeleteNarration(n.NarrationId)"><i class="bi bi-trash"></i></button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Chưa có bài thuyết minh nào.</td></tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@if (showNarrationModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-primary">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">@(isEditNarration ? "Sửa Thuyết minh" : "Thêm Thuyết minh")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showNarrationModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Ngôn ngữ</label>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngôn ngữ</label>
                            <select class="form-select" @bind="editingNarration.LanguageCode" disabled="@isEditNarration">
                                @if (availableLanguages != null && availableLanguages.Any())
                                {
                                    @* 👉 Ở Tab này, hiển thị TẤT CẢ ngôn ngữ (bao gồm cả Tiếng Việt) *@
                                    @foreach (var lang in availableLanguages)
                                    {
                                        <option value="@lang.LanguageCode">@lang.LanguageName (@lang.LanguageCode)</option>
                                    }
                                }
                                else
                                {
                                    <option value="vi">Tiếng Việt (vi) - Mặc định</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung thuyết minh (Text)</label>
                        <textarea class="form-control" rows="4" @bind="editingNarration.Text"></textarea>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="useAudioFile" @bind="editingNarration.UseAudioFile">
                        <label class="form-check-label fw-bold text-success" for="useAudioFile">Dùng File Audio tự thu âm?</label>
                    </div>

                    @if (editingNarration.UseAudioFile)
                    {
                        <div class="mb-3 bg-light p-3 rounded border">
                            <label class="form-label fw-bold"><i class="bi bi-cloud-upload"></i> Tải lên file Audio (.mp3, .wav)</label>
                            <InputFile OnChange="HandleFileSelected" class="form-control" accept="audio/*" />
                            @if (!string.IsNullOrEmpty(editingNarration.AudioUrl))
                            {
                                <small class="text-success mt-2 d-block"><i class="bi bi-check-circle-fill"></i> Đã có audio: @editingNarration.AudioUrl</small>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="mb-3 bg-light p-3 rounded border">
                            <label class="form-label fw-bold text-info"><i class="bi bi-robot"></i> Chọn giọng AI (TTS)</label>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Ngôn ngữ</label>
                                <select class="form-select" @bind="editingNarration.LanguageCode" disabled="@isEditNarration">
                                    @if (availableLanguages != null && availableLanguages.Any())
                                    {
                                        @* 👉 Ở Tab này, hiển thị TẤT CẢ ngôn ngữ (bao gồm cả Tiếng Việt) *@
                                        @foreach (var lang in availableLanguages)
                                        {
                                            <option value="@lang.LanguageCode">@lang.LanguageName (@lang.LanguageCode)</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="vi">Tiếng Việt (vi) - Mặc định</option>
                                    }
                                </select>
                            </div>
                        </div>
                    }

                    <div class="text-end mt-4">
                        <button class="btn btn-secondary" @onclick="() => showNarrationModal = false">Hủy</button>
                        <button class="btn btn-primary fw-bold px-4 ms-2" @onclick="SaveNarration" disabled="@isUploading">
                            @(isUploading ? "Đang lưu..." : "Lưu dữ liệu")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@if (showPoiTransModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-success shadow-lg">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-translate"></i> Dịch giới thiệu quán</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showPoiTransModal = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Chọn Ngôn ngữ</label>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngôn ngữ</label>
                            <select class="form-select" @bind="editingNarration.LanguageCode" disabled="@isEditNarration">
                                @if (availableLanguages != null && availableLanguages.Any())
                                {
                                    @* 👉 Ở Tab này, hiển thị TẤT CẢ ngôn ngữ (bao gồm cả Tiếng Việt) *@
                                    @foreach (var lang in availableLanguages)
                                    {
                                        <option value="@lang.LanguageCode">@lang.LanguageName (@lang.LanguageCode)</option>
                                    }
                                }
                                else
                                {
                                    <option value="vi">Tiếng Việt (vi) - Mặc định</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung giới thiệu (Mô tả chi tiết)</label>
                        <textarea class="form-control" rows="8" @bind="editingPoiTrans.Description"
                                  placeholder="Nhập nội dung giới thiệu bằng ngôn ngữ đã chọn..."></textarea>
                    </div>

                    <div class="alert alert-info small">
                        <i class="bi bi-info-circle"></i> Nội dung này sẽ hiển thị ở phần giới thiệu chi tiết của quán trên App Mobile khi khách chọn ngôn ngữ tương ứng.
                    </div>

                    <div class="text-end mt-4">
                        <button class="btn btn-secondary px-4" @onclick="() => showPoiTransModal = false">Hủy</button>
                        <button class="btn btn-success fw-bold px-4 ms-2" @onclick="SavePoiTrans">
                            <i class="bi bi-save"></i> Lưu bản dịch
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@code {
    [Parameter] public int Id { get; set; }

    private bool isLoading = true;
    private string activeTab = "info";
    private Restaurant? editingRes;

    // Biến cho Narration (Audio)
    private List<NarrationDto> narrations = new();
    private bool showNarrationModal = false;
    private bool isEditNarration = false;
    private NarrationDto editingNarration = new();

    // 👉 Thêm biến chứa ngôn ngữ
    private List<LanguageDto> availableLanguages = new();

    protected override async Task OnInitializedAsync()
    {
        editingRes = await RestaurantService.GetByIdAsync(Id);

        // 👉 Tải danh sách ngôn ngữ từ DB
        availableLanguages = await LanguageService.GetAllAsync();

        isLoading = false;
    }

    // ==========================================
    // XỬ LÝ TAB 1: THÔNG TIN CHUNG
    // ==========================================
    private async Task HandleSubmitInfo()
    {
        if (editingRes == null) return;
        var req = new UpdateRestaurantReq(editingRes.Name, editingRes.Address ?? "", editingRes.Description, editingRes.Latitude, editingRes.Longitude, editingRes.PoiId);
        bool success = await RestaurantService.UpdateAsync(Id, req);
        if (success) { await JS.InvokeVoidAsync("alert", "Cập nhật thành công!"); GoBack(); }
        else { await JS.InvokeVoidAsync("alert", "Lỗi cập nhật!"); }
    }

    private void GoBack() => Navigation.NavigateTo("/restaurants");

    // ==========================================
    // XỬ LÝ TAB 2: ÂM THANH / THUYẾT MINH
    // ==========================================
    private async Task LoadNarrations()
    {
        activeTab = "audio";
        if (editingRes != null)
        {
            // Lấy dữ liệu từ Backend
            narrations = await NarrationService.GetByPoiIdAsync(editingRes.PoiId);

            // 👇 Ép Blazor phải vẽ lại giao diện ngay lập tức
            StateHasChanged();
        }
    }

    private void OpenAddNarrationModal()
    {
        isEditNarration = false;
        editingNarration = new NarrationDto { PoiId = editingRes!.PoiId, LanguageCode = "vi", VoiceName = "vi-VN" };
        showNarrationModal = true;
    }

    private void OpenEditNarrationModal(NarrationDto n)
    {
        isEditNarration = true;
        editingNarration = new NarrationDto { NarrationId = n.NarrationId, PoiId = n.PoiId, LanguageCode = n.LanguageCode, Text = n.Text, UseAudioFile = n.UseAudioFile, VoiceName = n.VoiceName };
        showNarrationModal = true;
    }

    private IBrowserFile? selectedAudioFile;
    private bool isUploading = false;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedAudioFile = e.File;
    }

    private async Task SaveNarration()
    {
        // 👇 1. KIỂM TRA TRÙNG NGÔN NGỮ NGAY TẠI ĐÂY (Theo yêu cầu của Tài)
        if (!isEditNarration) // Chỉ kiểm tra khi Thêm mới
        {
            bool isExisted = narrations.Any(n => n.LanguageCode.ToLower() == editingNarration.LanguageCode.ToLower());
            if (isExisted)
            {
                await JS.InvokeVoidAsync("alert", $"Lỗi: Ngôn ngữ '{editingNarration.LanguageCode}' này đã có bản dịch. Vui lòng xóa bản cũ trước khi thêm mới hoặc chọn ngôn ngữ khác!");
                return; // Dừng lại không lưu
            }
        }

        isUploading = true;
        try
        {
            int currentNarrationId = editingNarration.NarrationId;
            bool isSuccess;
            string serverMsg;

            // 2. GỬI LỆNH LƯU
            if (isEditNarration)
            {
                var result = await NarrationService.UpdateAsync(currentNarrationId, new UpdateNarrationDto(editingNarration.Text, editingNarration.UseAudioFile, editingNarration.VoiceName));
                isSuccess = result.Success;
                serverMsg = result.Message;
            }
            else
            {
                // Lưu ý: Đổi tên DTO cho khớp với Backend của Tài (CreateNarrationDto)
                var result = await NarrationService.CreateAsync(new CreateNarrationDto(editingNarration.PoiId, editingNarration.LanguageCode, editingNarration.Text, editingNarration.UseAudioFile, editingNarration.VoiceName));
                isSuccess = result.Success;
                serverMsg = result.Message;
            }

            if (isSuccess)
            {
                // 3. NẾU CÓ CHỌN FILE AUDIO THÌ UPLOAD TIẾP
                if (editingNarration.UseAudioFile && selectedAudioFile != null)
                {
                    // Lấy lại ID nếu là thêm mới (bạn cần chỉnh backend trả về ID hoặc load lại list)
                    await NarrationService.UploadAudioAsync(currentNarrationId, selectedAudioFile);
                }

                showNarrationModal = false;
                await LoadNarrations(); // Tải lại bảng để thấy bản mới
            }
            else
            {
                // 👇 HIỆN LỖI CỤ THỂ TỪ SERVER (Giúp Tài biết chính xác lỗi gì)
                await JS.InvokeVoidAsync("alert", "Server báo lỗi: " + serverMsg);
            }
        }
        finally
        {
            isUploading = false;
        }
    }   

    private async Task DeleteNarration(int narrationId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Xóa bài thuyết minh này?"))
        {
            if (await NarrationService.DeleteAsync(narrationId)) await LoadNarrations();
        }
    }
    // ==========================================
    // XỬ LÝ TAB 3: GIỚI THIỆU ĐA NGÔN NGỮ
    // ==========================================
    private List<PoiTranslationDto> poiTranslations = new();
    private PoiTranslationDto editingPoiTrans = new();
    private bool showPoiTransModal = false;

    private async Task LoadPoiTranslations()
    {
        activeTab = "intro";
        if (editingRes != null)
        {
            poiTranslations = await PoiTransService.GetByPoiIdAsync(editingRes.PoiId);
            StateHasChanged();
        }
    }

    private void OpenPoiTransModal(PoiTranslationDto? t = null)
    {
        if (t != null)
        {
            // Chế độ Sửa
            editingPoiTrans = new PoiTranslationDto
            {
                TranslationId = t.TranslationId,
                PoiId = t.PoiId,
                LanguageCode = t.LanguageCode,
                Description = t.Description
            };
        }
        else
        {
            // Chế độ Thêm mới
            editingPoiTrans = new PoiTranslationDto
            {
                PoiId = editingRes!.PoiId,
                LanguageCode = "en",
                Description = "" // Đảm bảo ô nhập liệu trống khi thêm mới
            };
        }
        showPoiTransModal = true; // Lệnh này sẽ kích hoạt cái Modal bên trên hiện ra
    }

    private async Task SavePoiTrans()
    {
        if (string.IsNullOrWhiteSpace(editingPoiTrans.Description))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng nhập nội dung giới thiệu!");
            return;
        }

        bool success = await PoiTransService.SaveAsync(editingPoiTrans.PoiId, editingPoiTrans.LanguageCode, editingPoiTrans.Description);
        if (success)
        {
            showPoiTransModal = false;
            await LoadPoiTranslations();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Lỗi khi lưu bản dịch!");
        }
    }

    private async Task DeletePoiTrans(int transId)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa bản dịch giới thiệu này?"))
        {
            if (await PoiTransService.DeleteAsync(transId))
            {
                await LoadPoiTranslations();
            }
        }
    }
}