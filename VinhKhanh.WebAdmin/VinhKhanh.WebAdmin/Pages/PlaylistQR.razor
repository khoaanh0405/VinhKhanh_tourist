@page "/playlist-qr"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container mt-4">
    <button class="btn btn-outline-secondary mb-3 shadow-sm" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Quay lại Playlist
    </button>

    <div class="card shadow-lg border-0 rounded-4 mx-auto" style="max-width:500px;">
        <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
            <h4 class="mb-0 fw-bold">
                <i class="bi bi-collection-play me-2"></i>QR – Danh Sách Phát
            </h4>
        </div>

        <div class="card-body text-center p-5">
            @if (_isLoading)
            {
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải...</p>
            }
            else if (_playlist == null)
            {
                <div class="alert alert-danger">Không tìm thấy Playlist.</div>
            }
            else
            {
                <h5 class="fw-bold text-primary mb-1">@_playlist.Title</h5>
                <p class="text-muted small mb-4">
                    <i class="bi bi-geo-alt me-1"></i>@_playlist.ItemCount địa điểm
                </p>

                @if (string.IsNullOrEmpty(_qrValue))
                {
                    <div class="alert alert-warning mb-4">Playlist này chưa có mã QR.</div>
                    <button class="btn btn-success fw-bold px-4 py-2 shadow" @onclick="GenerateQR">
                        <i class="bi bi-magic me-2"></i> Tạo Mã QR Ngay
                    </button>
                }
                else
                {
                    <div class="bg-light p-3 rounded-4 d-inline-block border mb-3 shadow-sm">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=@_qrValue"
                             alt="QR Code" class="img-fluid rounded" />
                    </div>
                    <p class="font-monospace small text-muted mb-4">@_qrValue</p>
                    <hr />
                    <button class="btn btn-outline-danger btn-sm fw-bold" @onclick="DeleteQR">
                        <i class="bi bi-trash3 me-1"></i> Xóa mã QR này
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public int playlistId { get; set; }

    private bool _isLoading = true;
    private PlaylistSummaryDto? _playlist;
    private string _qrValue = "";
    private int _qrCodeId = 0;

    protected override async Task OnInitializedAsync()
    {
        if (playlistId <= 0) { _isLoading = false; return; }
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        try
        {
            var all = await Http.GetFromJsonAsync<List<PlaylistSummaryDto>>("api/Playlist");
            _playlist = all?.FirstOrDefault(p => p.PlaylistId == playlistId);

            var qrResp = await Http.GetAsync($"api/QRCode/playlist/{playlistId}");
            if (qrResp.IsSuccessStatusCode)
            {
                var qr = await qrResp.Content.ReadFromJsonAsync<QRCodeDto>();
                _qrValue = qr?.CodeValue ?? "";
                _qrCodeId = qr?.QRCodeId ?? 0;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        // QUAN TRỌNG: Phải có dòng này để tắt spinner
        _isLoading = false;
    }

    private async Task GenerateQR()
    {
        _isLoading = true;
        var resp = await Http.PostAsync($"api/QRCode/generate-playlist/{playlistId}", null);
        if (resp.IsSuccessStatusCode)
        {
            var qr = await resp.Content.ReadFromJsonAsync<QRCodeDto>();
            _qrValue = qr?.CodeValue ?? "";
            _qrCodeId = qr?.QRCodeId ?? 0;
        }
        _isLoading = false;
    }

    private async Task DeleteQR()
    {
        if (_qrCodeId == 0) return;
        if (!await JS.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa mã QR này?")) return;
        _isLoading = true;
        if ((await Http.DeleteAsync($"api/QRCode/{_qrCodeId}")).IsSuccessStatusCode)
        {
            _qrValue = ""; _qrCodeId = 0;
        }
        _isLoading = false;
    }

    private void GoBack() => Nav.NavigateTo("/playlists");

    public record PlaylistSummaryDto(int PlaylistId, string Title, int ItemCount, DateTime CreatedAt);
    public record QRCodeDto(int QRCodeId, string CodeValue);
}