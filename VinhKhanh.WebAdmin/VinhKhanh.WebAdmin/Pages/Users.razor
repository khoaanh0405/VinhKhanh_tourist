@page "/users"
@attribute [Authorize(Roles = "Admin")]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.IUserService UserService
@inject HttpClient Http
@inject IJSRuntime JS

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-danger fw-bold"><i class="bi bi-people-fill"></i> Quản lý Người dùng</h3>
    <button class="btn btn-success fw-bold" @onclick="OpenModal"><i class="bi bi-plus-circle"></i> Cấp tài khoản mới</button>
</div>

@if (users == null)
{
    <p class="text-center mt-5 text-muted">Đang tải dữ liệu...</p>
}
else
{
    <div class="card shadow-sm border-danger">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-danger">
                    <tr>
                        <th>ID</th>
                        <th>Tên hiển thị</th>
                        <th>Tài khoản</th>
                        <th>Email</th>
                        <th>Quyền</th>
                        <th>Ngày tạo</th>
                        <th class="text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in users)
                    {
                        <tr>
                            <td class="fw-bold text-secondary">#@u.UserId</td>
                            <td class="fw-bold">@u.DisplayName</td>
                            <td>@u.Username</td>
                            <td>@u.Email</td>
                            <td>
                                <span class="badge @(u.Role == "Admin" ? "bg-danger" : (u.Role == "Manager" ? "bg-warning text-dark" : "bg-secondary"))">@u.Role</span>
                            </td>
                            <td>@u.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => OpenPasswordModal(u.UserId, u.Username)">
                                    <i class="bi bi-key"></i> Đổi MK
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* --- MODAL TẠO TÀI KHOẢN --- *@
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-plus"></i> Cấp tài khoản quản lý</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger py-2">@errorMessage</div>
                    }

                    <EditForm Model="newUser" OnValidSubmit="HandleSubmit">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên hiển thị</label>
                            <InputText @bind-Value="newUser.DisplayName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tài khoản đăng nhập</label>
                            <InputText @bind-Value="newUser.Username" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Email</label>
                            <InputText @bind-Value="newUser.Email" type="email" class="form-control" placeholder="vidu@email.com" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Mật khẩu</label>
                            <InputText @bind-Value="newUser.Password" type="password" class="form-control" required />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">Chức vụ</label>
                            <InputSelect @bind-Value="newUser.Role" class="form-select">
                                <option value="Manager">Quản lý quán (Manager)</option>
                                <option value="Admin">Tổng quản lý (Admin)</option>
                            </InputSelect>
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModal">Hủy bỏ</button>
                            <button type="submit" class="btn btn-danger" disabled="@isSubmitting">
                                @(isSubmitting ? "Đang xử lý..." : "Lưu tài khoản")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@* --- MODAL ĐỔI MẬT KHẨU --- *@
@if (showPasswordModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-danger">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-key-fill"></i> Đổi mật khẩu</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="ClosePasswordModal"></button>
                </div>
                <div class="modal-body">
                    <p>Cấp lại mật khẩu cho tài khoản: <strong class="text-primary">@editUsername</strong></p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input type="password" @bind="newPassword" class="form-control" placeholder="Nhập mật khẩu mới..." />
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger py-2">@errorMessage</div>
                    }

                    <div class="d-flex justify-content-end gap-2">
                        <button class="btn btn-secondary" @onclick="ClosePasswordModal">Hủy</button>
                        <button class="btn btn-danger" @onclick="SubmitChangePassword" disabled="@isSubmitting">
                            @(isSubmitting ? "Đang xử lý..." : "Lưu mật khẩu")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<UserModel>? users;

    private bool showModal = false;
    private bool isSubmitting = false;
    private string errorMessage = "";
    private RegisterRequest newUser = new RegisterRequest();

    private bool showPasswordModal = false;
    private int editUserId = 0;
    private string editUsername = "";
    private string newPassword = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await UserService.GetUsersAsync();
    }

    private void OpenModal()
    {
        newUser = new RegisterRequest();
        errorMessage = "";
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = "";

        bool success = await UserService.CreateUserAsync(newUser);
        if (success)
        {
            await LoadUsers();
            showModal = false;
        }
        else
        {
            errorMessage = "Lỗi! Tài khoản đã tồn tại hoặc thiếu thông tin.";
        }
        isSubmitting = false;
    }

    private void OpenPasswordModal(int id, string username)
    {
        editUserId = id;
        editUsername = username;
        newPassword = "";
        errorMessage = "";
        showPasswordModal = true;
    }

    private void ClosePasswordModal() => showPasswordModal = false;

    private async Task SubmitChangePassword()
    {
        if (string.IsNullOrWhiteSpace(newPassword))
        {
            errorMessage = "Vui lòng nhập mật khẩu mới!";
            return;
        }

        isSubmitting = true;
        errorMessage = "";
        bool success = await UserService.ChangePasswordAsync(editUserId, newPassword);

        if (success)
        {
            showPasswordModal = false;
            await LoadUsers();
        }
        else
        {
            errorMessage = "Đổi mật khẩu thất bại!";
        }
        isSubmitting = false;
    }
}