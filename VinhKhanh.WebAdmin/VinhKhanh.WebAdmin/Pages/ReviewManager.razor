@page "/reviews"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <h3 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2"></i>Quản Lý Đánh Giá</h3>

    <div class="card shadow-sm border-0 rounded-3 mb-4">
        <div class="card-body">
            <div class="input-group mb-3" style="max-width: 500px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="Tìm kiếm nội dung đánh giá..."
                       @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <button class="btn btn-outline-secondary" @onclick="ClearSearch">Xóa</button>
                }
            </div>

            @if (reviews == null)
            {
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Người dùng</th>
                                <th>Đánh giá</th>
                                <th style="width: 40%;">Nội dung</th>
                                <th>Ngày tạo</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in reviews)
                            {
                                <tr class="@(r.IsHidden ? "table-secondary opacity-75" : "")">
                                    @* 👇 SỬ DỤNG HÀM TÌM TÊN ĐỂ HIỂN THỊ 👇 *@
                                    <td><strong>@GetUserName(r.UserId)</strong></td>

                                    <td>
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi @(i <= r.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (r.IsHidden)
                                        {
                                            <span class="badge bg-warning text-dark me-1">Đã ẩn</span>
                                        }
                                        <span class="@(r.IsHidden ? "text-decoration-line-through" : "")">@r.Comment</span>
                                    </td>
                                    <td class="small">@r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <div class="btn-group">
                                            <button class="btn btn-sm @(r.IsHidden ? "btn-success" : "btn-warning")"
                                                    @onclick="() => ToggleHide(r)">
                                                <i class="bi @(r.IsHidden ? "bi-eye" : "bi-eye-slash")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteReview(r)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public int? poiId { get; set; }

    private List<ReviewVM>? reviews;
    private string searchTerm = "";

    // 👇 1. TẠO 2 CÁI TỪ ĐIỂN ĐỂ LƯU MAP (ID -> TÊN) 👇
    private Dictionary<int, string> userNames = new();
    private Dictionary<int, string> poiNames = new();

    protected override async Task OnInitializedAsync()
    {
        // Khi mở trang, gọi data map 1 lần duy nhất
        await LoadMappingData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadReviews();
    }

    // 👇 2. HÀM TẢI TỪ ĐIỂN 👇
    private async Task LoadMappingData()
    {
        try
        {
            // Lấy danh sách Users (Nhớ check lại đường link API User của team bạn)
            var users = await Http.GetFromJsonAsync<List<UserDto>>("api/User");
            if (users != null)
                userNames = users.ToDictionary(u => u.UserId, u => u.DisplayName);
        }
        catch
        {
            // Nếu API chưa sẵn sàng thì web cũng không bị sập
        }
    }

    // 👇 3. HÀM LẤY TÊN TỪ TỪ ĐIỂN 👇
    private string GetUserName(int id) => userNames.TryGetValue(id, out var name) ? name : $"User #{id}";
    private string GetPoiName(int id) => poiNames.TryGetValue(id, out var name) ? name : $"POI #{id}";

    private async Task LoadReviews()
    {
        string url = $"api/Review?search={Uri.EscapeDataString(searchTerm)}";
        if (poiId.HasValue && poiId > 0) url += $"&poiId={poiId.Value}";

        reviews = await Http.GetFromJsonAsync<List<ReviewVM>>(url);
    }

    private async Task HandleSearch(KeyboardEventArgs e) { if (e.Key == "Enter") await LoadReviews(); }
    private async Task ClearSearch() { searchTerm = ""; await LoadReviews(); }

    private async Task ToggleHide(ReviewVM r)
    {
        var res = await Http.PutAsync($"api/Review/toggle-hide/{r.ReviewId}", null);
        if (res.IsSuccessStatusCode) r.IsHidden = !r.IsHidden;
    }

    private async Task DeleteReview(ReviewVM r)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Xóa vĩnh viễn đánh giá này?")) return;
        var res = await Http.DeleteAsync($"api/Review/{r.ReviewId}");
        if (res.IsSuccessStatusCode) reviews?.Remove(r);
    }

    // 👇 4. CLASS NHẬN DATA MỚI TỪ BACKEND (CHỈ CÓ ID) 👇
    public class ReviewVM
    {
        public int ReviewId { get; set; }
        public int UserId { get; set; } // Đổi thành UserId
        public int PoiId { get; set; }  // Đổi thành PoiId
        public int Rating { get; set; }
        public string? Comment { get; set; }
        public bool IsHidden { get; set; }
        public DateTime CreatedAt { get; set; }
    }

    // Class phụ để hứng data cho cuốn Từ điển
    public class UserDto { public int UserId { get; set; } public string DisplayName { get; set; } = ""; }
    public class PoiDto { public int PoiId { get; set; } public string Name { get; set; } = ""; }
}