@page "/restaurants"
@attribute [Authorize(Roles = "Admin, Manager")]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.IRestaurantService RestaurantService
@inject VinhKhanh.WebAdmin.Services.IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider
@using FuzzySharp
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HttpClient Http

<style>
    .custom-search-box {
        transition: all 0.3s ease-in-out;
        border-radius: 50rem;
        border: 2px solid #dee2e6;
        background-color: #f8f9fa;
        overflow: hidden;
    }
    .custom-search-box:hover {
        border-color: #86b7fe;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.15);
        background-color: #fff;
    }
    .custom-search-box:focus-within {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        background-color: #fff;
    }
    .custom-search-box .form-control {
        border: none;
        box-shadow: none;
        background: transparent;
    }
    .custom-search-box .input-group-text {
        border: none;
        background: transparent;
        color: #6c757d;
    }
    .custom-search-box:focus-within .input-group-text {
        color: #0d6efd;
    }
    .table-custom-row {
        transition: background-color 0.2s ease;
    }
    .table-custom-row:hover {
        background-color: #f1f8ff !important;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-shop me-2"></i>Quản lý Quán ăn & Địa điểm</h3>
    <AuthorizeView Roles="Admin">
        <button class="btn btn-primary fw-bold shadow-sm" @onclick="OpenAddModal">
            <i class="bi bi-plus-circle me-1"></i> Thêm Quán ăn mới
        </button>
    </AuthorizeView>
</div>

@if (restaurants == null)
{
    <div class="text-center mt-5 p-5">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
        <p class="mt-3 fw-bold text-muted">Đang tải dữ liệu, vui lòng chờ...</p>
    </div>
}
else
{
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <AuthorizeView Context="adminContext" Roles="Admin">
                <div class="row mb-4">
                    <div class="col-md-6 col-lg-5">
                        <div class="input-group custom-search-box px-3 py-2 shadow-sm">
                            <span class="input-group-text"><i class="bi bi-search fs-5"></i></span>
                            <input type="text" class="form-control fs-6"
                                   placeholder="Tìm kiếm tên quán ăn..."
                                   @bind="searchRestaurantString" @bind:event="oninput" />
                        </div>
                    </div>
                </div>
            </AuthorizeView>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th class="text-center" style="width: 80px;">ID</th>
                            <th style="width: 25%;">Thông Quán (Kèm POI)</th>
                            <th style="width: 20%;">Chủ quán</th>
                            <th style="width: 25%;">Địa chỉ</th>
                            <th class="text-end" style="min-width: 350px;">Bảng điều khiển</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (filteredRestaurants != null && filteredRestaurants.Any())
                        {
                            @foreach (var r in filteredRestaurants)
                            {
                                <tr class="table-custom-row" style="border-bottom: 1px solid #eee;">
                                    <td class="text-center fw-bold text-secondary">#@r.RestaurantId</td>
                                    <td>
                                        <div class="fw-bold fs-6 text-dark">@r.Name</div>
                                        <div class="small text-muted"><i class="bi bi-geo-alt"></i> POI ID: @r.PoiId</div>
                                    </td>
                                    <td>
                                        @if (string.IsNullOrEmpty(r.ManagerName))
                                        {
                                            <span class="badge bg-light text-muted border px-2 py-1">Chưa gán chủ</span>
                                        }
                                        else
                                        {
                                            <div class="fw-bold text-primary"><i class="bi bi-person-circle me-1"></i> @r.ManagerName</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="text-wrap" style="max-width: 250px;">@r.Address</div>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex flex-column gap-2 align-items-end">
                                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                <button class="btn btn-sm btn-info text-white fw-bold shadow-sm" @onclick="() => GoToMenu(r.RestaurantId)">
                                                    <i class="bi bi-card-list me-1"></i> Thực đơn
                                                </button>
                                                <button class="btn btn-sm btn-dark fw-bold shadow-sm" @onclick="() => GoToQR(r.RestaurantId)">
                                                    <i class="bi bi-qr-code me-1"></i> Mã QR
                                                </button>
                                                <button class="btn btn-sm btn-primary fw-bold shadow-sm" @onclick="() => GoToEdit(r.RestaurantId)">
                                                    <i class="bi bi-pencil-square me-1"></i> Sửa
                                                </button>
                                            </div>

                                            <AuthorizeView Context="adminContext" Roles="Admin">
                                                <div class="d-flex gap-2 justify-content-end flex-wrap mt-1">
                                                    <button class="btn btn-sm btn-warning fw-bold text-dark shadow-sm" @onclick="() => OpenAssignModal(r)">
                                                        <i class="bi bi-person-lines-fill me-1"></i> Gán chủ
                                                    </button>
                                                    <button class="btn btn-sm btn-outline-danger fw-bold bg-white" @onclick="() => DeleteRestaurant(r.RestaurantId)">
                                                        <i class="bi bi-trash3-fill me-1"></i> Xóa
                                                    </button>
                                                </div>
                                            </AuthorizeView>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted p-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Không tìm thấy quán ăn nào phù hợp với tìm kiếm của bạn.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (showEditModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4">
                <div class="modal-header text-white bg-success border-0 rounded-top-4">
                    <h5 class="modal-title fw-bold">
                        <i class="bi bi-plus-circle me-2"></i> Thêm mới Quán ăn
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showEditModal = false"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <EditForm Model="editingRes" OnValidSubmit="HandleSubmit">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Tên Quán ăn <span class="text-danger">*</span></label>
                            <InputText @bind-Value="editingRes.Name" class="form-control form-control-lg" placeholder="Nhập tên quán..." required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted">Địa chỉ <span class="text-danger">*</span></label>
                            <InputText @bind-Value="editingRes.Address" class="form-control form-control-lg" placeholder="Nhập địa chỉ..." required />
                        </div>
                        
                        <div class="card border-0 shadow-sm mb-3 border-start border-4 border-info">
                            <div class="card-body">
                                <label class="form-label fw-bold text-muted mb-1"><i class="bi bi-geo-alt-fill text-info me-1"></i> ID Địa điểm (POI ID)</label>
                                <InputNumber @bind-Value="editingRes.PoiId" class="form-control form-control-lg" required />
                                <small class="text-muted d-block mt-2 fst-italic">Liên kết quán này với một POI trên bản đồ thông qua ID.</small>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light border fw-bold px-4" @onclick="() => showEditModal = false">Hủy bỏ</button>
                            <button type="submit" class="btn btn-success fw-bold px-5 shadow-sm">
                                <i class="bi bi-floppy-fill me-1"></i> Lưu Dữ Liệu
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (showAssignModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0 rounded-4">
                <div class="modal-header bg-warning text-dark border-0 rounded-top-4">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-rolodex me-2"></i>Quản lý Chủ Quán</h5>
                    <button type="button" class="btn-close" @onclick="CloseAssignModal"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <p class="mb-4 fs-5 text-center">Đang thao tác quán: <strong class="text-primary">@selectedRestaurantName</strong></p>

                    @if (hasCurrentManager)
                    {
                        <div class="card border-info mb-4 shadow-sm">
                            <div class="card-body bg-info bg-opacity-10 d-flex justify-content-between align-items-center rounded">
                                <div>
                                    <span class="text-muted d-block small fw-bold">CHỦ QUÁN HIỆN TẠI</span>
                                    <strong class="fs-5 text-dark">@currentManagerName</strong>
                                </div>
                                <button class="btn btn-danger fw-bold shadow-sm" @onclick="RemoveManager" disabled="@isSubmitting">
                                    <i class="bi bi-person-dash-fill me-1"></i> Gỡ quyền
                                </button>
                            </div>
                        </div>
                    }

                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-body">
                            <label class="form-label fw-bold text-muted mb-3"><i class="bi bi-person-plus-fill me-1"></i>CHỌN NGƯỜI QUẢN LÝ MỚI</label>
                            <select class="form-select form-select-lg mb-2" @bind="selectedManagerId">
                                <option value="0">-- Vui lòng chọn một người --</option>
                                @foreach (var m in AvailableManagers)
                                {
                                    <option value="@m.UserId">@m.DisplayName (@m.Username)</option>
                                }
                            </select>
                            <small class="text-muted fst-italic">* Danh sách chỉ hiển thị những Manager chưa được gán quán nào.</small>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger py-2 fw-bold text-center"><i class="bi bi-exclamation-triangle-fill me-1"></i>@errorMessage</div>
                    }

                    <div class="d-flex justify-content-end gap-2 border-top pt-3">
                        <button class="btn btn-light border fw-bold px-4" @onclick="CloseAssignModal">Đóng</button>
                        <button class="btn btn-warning text-dark fw-bold px-5 shadow-sm" @onclick="SubmitAssignManager" disabled="@(isSubmitting || selectedManagerId == 0)">
                            <i class="bi bi-check-circle-fill me-1"></i> Xác nhận Gán
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Restaurant>? restaurants;
    private List<UserModel>? managers;
    private bool isAdmin = false;
    private string searchRestaurantString = "";

    private bool showAssignModal = false;
    private int selectedRestaurantId = 0;
    private string selectedRestaurantName = "";
    private string currentManagerName = "";
    private bool hasCurrentManager = false;
    private int selectedManagerId = 0;
    private bool isSubmitting = false;
    private string errorMessage = "";

    private List<UserModel> AvailableManagers => managers?
        .Where(m => !restaurants!.Any(r => r.ManagerUserId == m.UserId))
        .ToList() ?? new List<UserModel>();

    private bool showEditModal = false;
    private bool isEdit = false;

    private class FormModel
    {
        public string Name { get; set; } = "";
        public string Address { get; set; } = "";
        public int PoiId { get; set; }
    }
    private FormModel editingRes = new();

    private IEnumerable<Restaurant>? filteredRestaurants =>
        string.IsNullOrWhiteSpace(searchRestaurantString)
            ? restaurants
            : restaurants?.Where(r => Fuzz.PartialRatio(searchRestaurantString.ToLower(), r.Name.ToLower()) > 65);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole("Admin");
        await LoadData();
        if (isAdmin)
        {
            var allUsers = await UserService.GetUsersAsync();
            managers = allUsers.Where(u => u.Role == "Manager").ToList();
        }
    }

    private async Task LoadData()
    {
        if (isAdmin) restaurants = await RestaurantService.GetAllAsync();
        else restaurants = await RestaurantService.GetMyAsync();
    }

    private void GoToMenu(int restaurantId) => Navigation.NavigateTo($"/restaurants/{restaurantId}/foods");
    private void GoToQR(int restaurantId) => Navigation.NavigateTo($"/qrcodes?restaurantId={restaurantId}");
    private void GoToEdit(int restaurantId) => Navigation.NavigateTo($"/restaurants/edit/{restaurantId}");

    private void OpenAddModal()
    {
        isEdit = false;
        editingRes = new FormModel { PoiId = 1 };
        showEditModal = true;
    }

    private void OpenAssignModal(Restaurant r)
    {
        selectedRestaurantId = r.RestaurantId;
        selectedRestaurantName = r.Name;
        currentManagerName = r.ManagerName ?? "";
        hasCurrentManager = r.ManagerUserId.HasValue && r.ManagerUserId > 0;
        selectedManagerId = 0;
        errorMessage = "";
        showAssignModal = true;
    }

    private async Task RemoveManager()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn gỡ quyền quản lý của {currentManagerName} khỏi quán này?")) return;
        isSubmitting = true;
        bool success = await RestaurantService.AssignManagerAsync(selectedRestaurantId, 0);
        if (success)
        {
            showAssignModal = false;
            await LoadData();
        }
        else errorMessage = "Gỡ chủ quán thất bại!";
        isSubmitting = false;
    }

    private async Task SubmitAssignManager()
    {
        if (selectedManagerId == 0) return;
        isSubmitting = true;
        bool success = await RestaurantService.AssignManagerAsync(selectedRestaurantId, selectedManagerId);
        if (success) { showAssignModal = false; await LoadData(); }
        else errorMessage = "Gán thất bại!";
        isSubmitting = false;
    }

    private void CloseAssignModal() => showAssignModal = false;

    private async Task HandleSubmit()
    {
        bool success = await RestaurantService.CreateAsync(new CreateRestaurantReq(editingRes.Name, editingRes.Address, editingRes.PoiId));
        if (success) { showEditModal = false; await LoadData(); }
        else await JS.InvokeVoidAsync("alert", "Lưu dữ liệu thất bại!");
    }

    private async Task DeleteRestaurant(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa quán ăn này không?"))
        {
            if (await RestaurantService.DeleteAsync(id)) await LoadData();
        }
    }
}