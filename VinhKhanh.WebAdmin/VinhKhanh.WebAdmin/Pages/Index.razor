@page "/"
@attribute [Authorize]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.DashboardService DashboardService

<PageTitle>Tổng quan hệ thống</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-speedometer2"></i> Tổng quan hệ thống (Dashboard)</h3>
</div>

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-primary border-4 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">Địa điểm (POIs)</div>
                            <div class="h3 mb-0 fw-bold text-gray-800">@stats.TotalPois</div>
                        </div>
                        <i class="bi bi-geo-alt fs-1 text-gray-300 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-success border-4 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-xs fw-bold text-success text-uppercase mb-1">Quán ăn</div>
                            <div class="h3 mb-0 fw-bold text-gray-800">@stats.TotalRestaurants</div>
                        </div>
                        <i class="bi bi-shop fs-1 text-gray-300 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-info border-4 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-xs fw-bold text-info text-uppercase mb-1">Món ăn (Menu)</div>
                            <div class="h3 mb-0 fw-bold text-gray-800">@stats.TotalFoods</div>
                        </div>
                        <i class="bi bi-menu-button-wide fs-1 text-gray-300 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-warning border-4 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-xs fw-bold text-warning text-uppercase mb-1">Lượt đánh giá</div>
                            <div class="h3 mb-0 fw-bold text-gray-800">@stats.TotalReviews</div>
                        </div>
                        <i class="bi bi-star fs-1 text-gray-300 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold text-primary"><i class="bi bi-trophy text-warning"></i> Top 5 Quán ăn được đánh giá cao nhất</h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Hạng</th>
                                <th>Tên Quán (POI)</th>
                                <th>Điểm TB</th>
                                <th>Số lượt đánh giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (stats.TopPois != null && stats.TopPois.Any())
                            {
                                int rank = 1;
                                @foreach (var poi in stats.TopPois)
                                {
                                    <tr>
                                        <td class="ps-3 fw-bold text-muted">#@rank</td>
                                        <td class="fw-bold text-dark">@poi.Name</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="fs-5 fw-bold text-warning me-2">@poi.AverageRating.ToString("0.0")</span>
                                                <div>
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        if (i <= Math.Round(poi.AverageRating))
                                                        {
                                                            <i class="bi bi-star-fill text-warning"></i>
                                                        }
                                                        else
                                                        {
                                                            <i class="bi bi-star text-warning opacity-25"></i>
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="badge bg-secondary rounded-pill fs-6">@poi.ReviewCount lượt</span></td>
                                    </tr>
                                    rank++;
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center py-4 text-muted">Chưa có dữ liệu đánh giá.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-primary text-white">
                <div class="card-body">
                    <h5 class="fw-bold"><i class="bi bi-lightbulb"></i> Mẹo quản trị</h5>
                    <p class="mb-0 mt-3">Các quán ăn có điểm đánh giá cao sẽ được ưu tiên hiển thị trên Ứng dụng di động của du khách. Hãy nhắc nhở các quản lý nhà hàng (Manager) thường xuyên cập nhật Menu và hình ảnh để thu hút thêm khách nhé!</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStatsDto stats = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        stats = await DashboardService.GetStatsAsync();
        isLoading = false;
    }
}