@page "/"
@attribute [Authorize]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.DashboardService DashboardService
@implements IDisposable

<PageTitle>Tổng quan hệ thống</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-speedometer2"></i> Tổng quan Hệ thống (Live)</h3>
    @if (isPolling)
    {
        <span class="badge bg-success rounded-pill px-3 py-2 animate-pulse">
            <span class="spinner-grow spinner-grow-sm me-1" role="status" aria-hidden="true"></span>
            Đang cập nhật trực tiếp...
        </span>
    }
</div>

@if (isLoading)
{
    <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="row mb-5 g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-lg bg-gradient-primary text-white h-100 rounded-4" style="background: linear-gradient(135deg, #0d6efd, #0dcaf0);">
                <div class="card-body p-4 position-relative overflow-hidden">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1"><i class="bi bi-broadcast"></i> Đang Online (Active)</h6>
                    <div class="display-3 fw-bold mb-0">@stats.ActiveUsers <span class="fs-4 fw-normal opacity-75">user</span></div>
                    <i class="bi bi-person-lines-fill position-absolute text-white opacity-25" style="font-size: 6rem; bottom: -10px; right: -10px;"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-lg bg-gradient-success text-white h-100 rounded-4" style="background: linear-gradient(135deg, #198754, #20c997);">
                <div class="card-body p-4 position-relative overflow-hidden">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1"><i class="bi bi-phone"></i> Tổng Lượt Truy Cập</h6>
                    <div class="display-3 fw-bold mb-0">@stats.TotalVisits <span class="fs-4 fw-normal opacity-75">máy</span></div>
                    <i class="bi bi-phone-vibrate position-absolute text-white opacity-25" style="font-size: 6rem; bottom: -10px; right: 10px;"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-lg bg-gradient-warning text-dark h-100 rounded-4" style="background: linear-gradient(135deg, #ffc107, #fd7e14);">
                <div class="card-body p-4 position-relative overflow-hidden">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-1"><i class="bi bi-qr-code-scan"></i> Tổng Lượt Quét QR</h6>
                    <div class="display-3 fw-bold mb-0">@stats.TotalQrScans <span class="fs-4 fw-normal opacity-75">lượt</span></div>
                    <i class="bi bi-qr-code position-absolute text-dark opacity-10" style="font-size: 6rem; bottom: -10px; right: 10px;"></i>
                </div>
            </div>
        </div>
    </div>

    <h6 class="text-muted fw-bold text-uppercase mb-3">Thống kê Dữ liệu Hệ thống</h6>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-primary border-3">
                <div class="card-body py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-bold small"><i class="bi bi-geo-alt"></i> Địa điểm (POIs)</span>
                    <span class="badge bg-primary rounded-pill fs-6">@stats.TotalPois</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-success border-3">
                <div class="card-body py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-bold small"><i class="bi bi-shop"></i> Quán ăn (Restaurants)</span>
                    <span class="badge bg-success rounded-pill fs-6">@stats.TotalRestaurants</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 border-start border-info border-3">
                <div class="card-body py-2 d-flex justify-content-between align-items-center">
                    <span class="text-muted fw-bold small"><i class="bi bi-menu-button-wide"></i> Món ăn (Menu)</span>
                    <span class="badge bg-info rounded-pill fs-6">@stats.TotalFoods</span>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .animate-pulse {
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
</style>

@code {
    private DashboardStatsDto stats = new();
    private bool isLoading = true;
    private bool isPolling = false;
    private System.Threading.Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        isLoading = false;
        
        // Thiết lập bộ đếm giờ (Polling) mỗi 10 giây để lấy số người đang Online
        _timer = new System.Threading.Timer(async _ =>
        {
            isPolling = true;
            await InvokeAsync(StateHasChanged);

            await LoadData();
            
            isPolling = false;
            await InvokeAsync(StateHasChanged);

        }, null, 10000, 10000); // Đợi 10s chạy lần đầu, sau đó lặp lại mỗi 10s
    }

    private async Task LoadData()
    {
        stats = await DashboardService.GetStatsAsync();
    }

    // Quan trọng: Phải giải phóng Timer khi rời khỏi trang để tránh Memory Leak
    public void Dispose()
    {
        _timer?.Dispose();
    }
}