@page "/languages"
@attribute [Authorize(Roles = "Admin, Manager")]
@using VinhKhanh.WebAdmin.Models
@inject VinhKhanh.WebAdmin.Services.ILanguageService LanguageService
@inject IJSRuntime JS
@inject HttpClient Http

<div class="d-flex justify-content-between mb-4">
    <h3 class="text-primary fw-bold"><i class="bi bi-globe"></i> Quản lý Ngôn ngữ & Dịch thuật</h3>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm border-primary">
            <div class="card-header bg-primary text-white fw-bold">Thêm Ngôn ngữ mới</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="fw-bold mb-2">Chọn ngôn ngữ (Hỗ trợ TTS)</label>
                    <select class="form-select" @bind="selectedLanguageCode">
                        <option value="">-- Vui lòng chọn ngôn ngữ --</option>
                        @foreach (var lang in GoogleLanguages.SupportedLanguages)
                        {
                            <option value="@lang.Key">@lang.Value (@lang.Key)</option>
                        }
                    </select>
                    <small class="text-muted mt-1 d-block"><i>*Danh sách đã được lọc để đảm bảo 100% có giọng đọc AI.</i></small>
                </div>
                <button class="btn btn-success w-100 fw-bold" @onclick="SaveLanguage">Thêm Ngôn ngữ</button>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Mã CODE</th>
                            <th>Tên Ngôn ngữ</th>
                            <th class="text-center">Đồng bộ Dữ liệu</th>
                            <th class="text-end">Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in languages)
                        {
                            var currentCode = l.LanguageCode;
                            <tr>
                                <td class="fw-bold text-primary">@l.LanguageCode</td>
                                <td>@l.LanguageName</td>
                                <td class="text-center">
                                    @if (l.LanguageCode != "vi")
                                    {
                                        <button class="btn btn-sm btn-info text-white fw-bold shadow-sm"
                                                @onclick="() => AutoTranslateAll(l.LanguageCode)"
                                                disabled="@isTranslating">
                                            <i class="bi bi-magic"></i> @(isTranslating ? "Đang đồng bộ..." : "Dịch Toàn Tập")
                                        </button>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLanguage(l.LanguageCode)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<LanguageDto> languages = new();
    private LanguageDto newLang = new();
    private bool isTranslating = false;
    private string selectedLanguageCode = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData() => languages = await LanguageService.GetAllAsync();

    private async Task SaveLanguage()
    {
        if (string.IsNullOrEmpty(selectedLanguageCode))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng chọn một ngôn ngữ từ danh sách!");
            return;
        }

        newLang.LanguageCode = selectedLanguageCode;
        newLang.LanguageName = GoogleLanguages.SupportedLanguages[selectedLanguageCode];

        if (await LanguageService.CreateAsync(newLang))
        {
            newLang = new();
            selectedLanguageCode = "";
            await LoadData();
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Lỗi: Ngôn ngữ này đã có trong hệ thống rồi!");
        }
    }

    private async Task DeleteLanguage(string code)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa ngôn ngữ '{code}'? Mọi bản dịch liên quan sẽ bị xóa sạch."))
        {
            bool isSuccess = await LanguageService.DeleteAsync(code);
            if (isSuccess)
            {
                await LoadData();
                StateHasChanged();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Lỗi: Không thể xóa ngôn ngữ!");
            }
        }
    }

    private async Task AutoTranslateAll(string targetLangCode)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Hệ thống sẽ dịch TOÀN BỘ Giao diện, Tên món ăn và Bài thuyết minh sang '{targetLangCode}'. Quá trình này sẽ mất một chút thời gian. Bắt đầu ngay?"))
            return;

        isTranslating = true;
        StateHasChanged();

        try
        {
            // Gọi đến API mới tạo
            var response = await Http.PostAsync($"api/Translate/auto-all/{targetLangCode}", null);

            if (response.IsSuccessStatusCode)
            {
                var successMsg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", successMsg);
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Lỗi dịch thuật: {errorMsg}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi kết nối máy chủ: {ex.Message}");
        }
        finally
        {
            isTranslating = false;
            StateHasChanged();
        }
    }
}