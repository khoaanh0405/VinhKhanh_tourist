@page "/qrcodes"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="container mt-4">
    <button class="btn btn-outline-secondary mb-3 shadow-sm" @onclick="GoBack">
        <i class="bi bi-arrow-left"></i> Quay lại
    </button>

    <div class="card shadow-lg border-0 rounded-4 mx-auto" style="max-width: 500px;">
        <div class="card-header bg-dark text-white text-center py-3 rounded-top-4">
            <h4 class="mb-0 fw-bold"><i class="bi bi-qr-code-scan me-2"></i>Quản Lý Mã QR</h4>
        </div>
        <div class="card-body text-center p-5">

            @if (isLoading)
            {
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
            }
            else if (restaurantInfo == null)
            {
                <div class="alert alert-danger">Không tìm thấy thông tin quán ăn.</div>
            }
            else
            {
                <h5 class="fw-bold text-primary mb-1">@restaurantInfo.Name</h5>
                <p class="text-muted small mb-4">@restaurantInfo.Address</p>

                @if (string.IsNullOrEmpty(qrCodeValue))
                {
                    <div class="alert alert-warning mb-4">Quán này chưa được tạo mã QR.</div>
                    <button class="btn btn-success fw-bold px-4 py-2 shadow" @onclick="GenerateQR">
                        <i class="bi bi-magic me-2"></i> Tạo Mã QR Ngay
                    </button>
                }
                else
                {
                    <div class="bg-light p-3 rounded-4 d-inline-block border mb-3 shadow-sm">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=@qrCodeValue"
                             alt="QR Code" class="img-fluid rounded" />
                    </div>

                    <h4 class="fw-bold text-dark mt-2 tracking-widest" style="letter-spacing: 2px;">@qrCodeValue</h4>
                    <p class="text-muted small mb-4">Quét mã này để truy cập trên Mobile App.</p>

                    <hr />
                    <button class="btn btn-outline-danger btn-sm fw-bold" @onclick="DeleteQR">
                        <i class="bi bi-trash3 me-1"></i> Xóa mã QR này
                    </button>
                }
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public int restaurantId { get; set; }

    private bool isLoading = true;
    private RestaurantDto? restaurantInfo;
    private string qrCodeValue = "";
    private int qrCodeId = 0; // Lưu ID để xóa

    protected override async Task OnInitializedAsync()
    {
        if (restaurantId > 0) await LoadData();
        else isLoading = false;
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            restaurantInfo = await Http.GetFromJsonAsync<RestaurantDto>($"api/Restaurant/{restaurantId}");

            if (restaurantInfo != null)
            {
                var response = await Http.GetAsync($"api/QRCode/poi/{restaurantInfo.PoiId}");
                if (response.IsSuccessStatusCode)
                {
                    var qrData = await response.Content.ReadFromJsonAsync<QRCodeDto>();
                    qrCodeValue = qrData?.CodeValue ?? "";
                    qrCodeId = qrData?.QRCodeId ?? 0; // Lấy ID từ Server trả về
                }
                else
                {
                    qrCodeValue = "";
                    qrCodeId = 0;
                }
            }
        }
        catch { }
        finally { isLoading = false; }
    }

    private async Task GenerateQR()
    {
        if (restaurantInfo == null) return;
        isLoading = true;

        var response = await Http.PostAsync($"api/QRCode/generate/{restaurantInfo.PoiId}", null);
        if (response.IsSuccessStatusCode)
        {
            var qrData = await response.Content.ReadFromJsonAsync<QRCodeDto>();
            qrCodeValue = qrData?.CodeValue ?? "";
            qrCodeId = qrData?.QRCodeId ?? 0;
        }
        isLoading = false;
    }

    // 👇 HÀM XỬ LÝ XÓA 👇
    private async Task DeleteQR()
    {
        if (qrCodeId == 0) return;

        // Hiện xác nhận cho chắc ăn
        bool confirm = await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa mã QR này không?");
        if (!confirm) return;

        isLoading = true;
        var response = await Http.DeleteAsync($"api/QRCode/{qrCodeId}");

        if (response.IsSuccessStatusCode)
        {
            qrCodeValue = "";
            qrCodeId = 0;
            // Thông báo thành công
            await JS.InvokeVoidAsync("alert", "Đã xóa mã QR thành công!");
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Lỗi: Không thể xóa mã QR.");
        }
        isLoading = false;
    }

    private void GoBack() => Nav.NavigateTo("/restaurants");

    public class RestaurantDto { public string Name { get; set; } = ""; public string Address { get; set; } = ""; public int PoiId { get; set; } }

    // Cập nhật DTO để lấy thêm QRCodeId
    public class QRCodeDto
    {
        public int QRCodeId { get; set; }
        public string CodeValue { get; set; } = "";
    }
}